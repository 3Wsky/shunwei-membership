.card {
  padding: 28rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.title { font-size: 28rpx; font-weight: 700; color: #1a1a1a; margin-bottom: 16rpx; }

.plan {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.plan:last-child { border-bottom: none; }

.plan-head { display: flex; justify-content: space-between; align-items: center; }

.plan-name { font-size: 28rpx; font-weight: 600; color: #1a1a1a; }

.plan-price { font-size: 34rpx; font-weight: 800; }

.gold { color: #c9a227; }

.premium { color: #7b4fd4; }

.plan-gift { font-size: 24rpx; color: #8c8c8c; margin-top: 8rpx; display: block; }
