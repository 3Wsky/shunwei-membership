  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "fastify": "^5.8.5",
    "mysql2": "^3.22.4",
    "nanoid": "^5.1.11",
    "zod": "^4.4.3"
  }
}
