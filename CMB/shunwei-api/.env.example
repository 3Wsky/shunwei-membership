PORT=8787
HOST=127.0.0.1
NODE_ENV=production
LOG_LEVEL=info
DATA_DIR=./data
PRICE_TAG_DATA_DIR=../digital-price-tag-generator/public/data

# Admin console.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_SESSION_SECRET=replace-with-a-random-string-at-least-24-chars
ADMIN_SESSION_MAX_AGE=28800

# CRMEB bridge.
CRMEB_APP_KEY=app_key_69e81b63719a8
CRMEB_DB_HOST=127.0.0.1
CRMEB_DB_PORT=3306
CRMEB_DB_USER=root
CRMEB_DB_PASSWORD=root
CRMEB_DB_NAME=crmeb
CRMEB_DB_PREFIX=eb_
CRMEB_DB_CHARSET=utf8mb4
CRMEB_DB_CONNECTION_LIMIT=5
CRMEB_TOKEN_LEEWAY_SECONDS=60

# AI 生图（gpt-image-2，OpenAI 兼容协议）— 门店礼品 AI 采集用（可选）
# 未配置时「AI 拍照生成礼品」入口返回 503，不影响其它采集方式
IMAGE_GEN_BASE_URL=https://api.fastapi.ai
IMAGE_GEN_API_KEY=replace-with-your-image-api-key
AI_IMAGE_MODEL=gpt-image-2
AI_IMAGE_QUALITY=medium
