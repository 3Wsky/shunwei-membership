{
  "apis": [
    {
      "name": "queryMyMembership",
      "description": "查询当前登录用户的会员等级、到期时间、积分摘要。用户问「我是不是会员」「什么等级」时调用。需已登录，token 从 storage 键 SW_TOKEN 读取。",
      "_meta": {
        "ui": {
          "componentPath": "components/membership-card/index"
        }
      },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "uid": { "type": "number" },
          "nickname": { "type": "string" },
          "tierLabel": { "type": "string", "description": "199会员/299会员/普通用户" },
          "tierCode": { "type": "string" },
          "isMemberActive": { "type": "boolean" },
          "expireAt": { "type": "number", "description": "到期时间戳，0表示无" },
          "expireText": { "type": "string" },
          "integralTotal": { "type": "number" },
          "giftRemaining": { "type": "number" },
          "rechargeRemaining": { "type": "number" }
        }
      }
    },
    {
      "name": "queryMyIntegral",
      "description": "查询当前用户积分余额（总积分、赠送积分、充值积分）。用户问「多少积分」时调用。需已登录。",
      "_meta": {
        "ui": {
          "componentPath": "components/integral-card/index"
        }
      },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "total": { "type": "number" },
          "giftRemaining": { "type": "number" },
          "rechargeRemaining": { "type": "number" },
          "expiringSoon": { "type": "number" }
        }
      }
    },
    {
      "name": "queryMembershipPlans",
      "description": "查询 199/299 会员套餐列表（价格、赠送积分、有效期）。无需登录。用户问套餐区别、开通价格时调用。",
      "_meta": {
        "ui": {
          "componentPath": "components/plans-card/index"
        }
      },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "plans": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "tierCode": { "type": "string" },
                "title": { "type": "string" },
                "price": { "type": "number" },
                "giftIntegral": { "type": "number" },
                "vipDays": { "type": "number" }
              }
            }
          }
        }
      }
    },
    {
      "name": "queryMyCashVoucher",
      "description": "查询当前用户现金券钱包余额。用户问「现金券还有多少」时调用。需已登录。",
      "_meta": {
        "ui": {
          "componentPath": "components/voucher-card/index"
        }
      },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "balance": { "type": "number" },
          "batchCount": { "type": "number" },
          "expiringSoon": { "type": "number" }
        }
      }
    }
  ],
  "components": [
    {
      "path": "components/membership-card/index",
      "relatedPage": "/pages/member/center"
    },
    {
      "path": "components/integral-card/index",
      "relatedPage": "/pages/integral/index"
    },
    {
      "path": "components/plans-card/index",
      "relatedPage": "/pages/member/purchase"
    },
    {
      "path": "components/voucher-card/index",
      "relatedPage": "/pages/voucher/wallet"
    }
  ]
}
