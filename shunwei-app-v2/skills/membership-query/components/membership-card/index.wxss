.card {

  padding: 28rpx;

  background: linear-gradient(135deg, #1a1f36 0%, #2d3561 100%);

  border-radius: 24rpx;

  color: #fff;

  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);

}

.card-header {

  display: flex;

  justify-content: space-between;

  align-items: center;

  margin-bottom: 20rpx;

}

.label { font-size: 24rpx; opacity: 0.75; }

.tier { font-size: 32rpx; font-weight: 700; }

.tier.gold { color: #d4af37; }

.tier.silver { color: #c0c0c0; }

.row {

  display: flex;

  justify-content: space-between;

  font-size: 26rpx;

  margin-bottom: 12rpx;

}

.muted { opacity: 0.65; }

.val.gold { color: #d4af37; font-weight: 600; }

.integral-row {

  display: flex;

  margin-top: 16rpx;

  padding-top: 16rpx;

  border-top: 1rpx solid rgba(255, 255, 255, 0.15);

}

.integral-item { flex: 1; text-align: center; }

.num { display: block; font-size: 36rpx; font-weight: 700; }

.num.gold { color: #d4af37; }

.sub { font-size: 22rpx; opacity: 0.7; }

