  <view class="row">
    <view class="item"><text class="num">{{data.giftRemaining || 0}}</text><text class="sub">赠送积分</text></view>
    <view class="item"><text class="num">{{data.rechargeRemaining || 0}}</text><text class="sub">充值积分</text></view>
  </view>
</view>
