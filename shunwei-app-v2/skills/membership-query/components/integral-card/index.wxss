.card {
  padding: 28rpx;
  background: linear-gradient(135deg, #1a1f36 0%, #2d3561 100%);
  border-radius: 24rpx;
  color: #fff;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.title { font-size: 24rpx; opacity: 0.75; }

.total {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  margin: 12rpx 0;
  color: #d4af37;
}

.gold { color: #d4af37; }

.row { display: flex; gap: 24rpx; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid rgba(255, 255, 255, 0.15); }

.item { flex: 1; text-align: center; }

.num { display: block; font-size: 32rpx; font-weight: 700; color: #fff; }

.sub { font-size: 22rpx; opacity: 0.7; }
