<view class="card">
  <text class="title">会员套餐</text>
  <view class="plan" wx:for="{{plans}}" wx:key="tierCode">
    <view class="plan-head">
      <text class="plan-name">{{item.title}}</text>
      <text class="plan-price gold">¥{{item.price}}</text>
    </view>
    <text class="plan-gift">赠 {{item.giftIntegral}} 积分 · {{item.vipDays}} 天</text>
  </view>
</view>
