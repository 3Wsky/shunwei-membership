/* 复用 pages/user/index.wxss 中 .new-users .user-menus 样式（apply-shared） */
.menu-icon{
  display:block;
  font-size:52rpx;
  line-height:52rpx;
  color:var(--view-theme);
  margin-bottom:18rpx
}
.menu-icon-inline{
  font-size:40rpx;
  color:var(--view-theme);
  margin-right:20rpx
}
.manager-box{
  padding-top:0!important;
  padding-bottom:0!important
}
.manager-box .item{
  margin-bottom:24rpx!important
}
.pending-tag{
  margin-left:12rpx;
  font-size:22rpx;
  color:var(--view-theme);
  font-weight:400
}
.jc-icon-wrap{
  position:relative;
  display:flex;
  flex-direction:column;
  align-items:center
}
.pending-badge{
  position:absolute;
  top:-12rpx;
  right:-18rpx;
  min-width:32rpx;
  height:32rpx;
  padding:0 7rpx;
  border-radius:999rpx;
  background:#ff3b30;
  color:#fff;
  font-size:18rpx;
  line-height:28rpx;
  text-align:center;
  font-weight:700;
  box-sizing:border-box;
  border:2rpx solid #ffffff;
  box-shadow:0 2rpx 8rpx rgba(255,59,48,0.3)
}

