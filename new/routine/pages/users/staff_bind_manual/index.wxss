page {
  min-height: 100%;
  background: #F5F3F0;
}

.manager-page {
  min-height: 100vh;
  padding: 28rpx 32rpx 54rpx;
  box-sizing: border-box;
  color: #1A1A1A;
  background: #F5F3F0;
}

.manager-card,
.staff-bind-card,
.state-card {
  border: 1rpx solid rgba(201, 162, 39, 0.08);
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.manager-card,
.staff-bind-card {
  overflow: hidden;
}

.manager-hero,
.staff-bind-hero {
  position: relative;
  box-sizing: border-box;
  overflow: hidden;
  color: #FFFFFF;
  background: linear-gradient(135deg, #1A1F36 0%, #2D3561 100%);
  box-shadow: 0 12rpx 36rpx rgba(26, 31, 54, 0.16);
}

.manager-hero {
  display: flex;
  align-items: center;
  min-height: 246rpx;
  padding: 42rpx 34rpx;
}

.staff-bind-hero {
  min-height: 230rpx;
  padding: 36rpx 34rpx 34rpx;
}

.manager-mark {
  position: absolute;
  right: 28rpx;
  top: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 176rpx;
  height: 176rpx;
  border-radius: 48rpx;
  color: rgba(255, 255, 255, 0.15);
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.02));
  transform: rotate(10deg);
}

.manager-mark .iconfont {
  font-size: 100rpx;
}

.bind-mark {
  right: 26rpx;
  top: 28rpx;
}

.manager-avatar {
  position: relative;
  z-index: 2;
  width: 132rpx;
  height: 132rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 50%;
  background: #F5F3F0;
  box-shadow: 0 10rpx 26rpx rgba(15, 35, 70, 0.16);
}

.manager-main {
  position: relative;
  z-index: 2;
  flex: 1;
  min-width: 0;
  margin-left: 26rpx;
  padding-right: 94rpx;
}

.manager-name,
.staff-bind-title {
  color: #FFFFFF;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.35;
}

.manager-role,
.staff-bind-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.75);
  font-size: 25rpx;
  line-height: 1.5;
}

.staff-bind-title,
.staff-bind-desc {
  position: relative;
  z-index: 2;
  max-width: 430rpx;
}

.manager-uid {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  height: 38rpx;
  margin-top: 16rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.34);
  border-radius: 19rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.12);
}

.manager-bio {
  padding: 30rpx 34rpx 0;
  color: #4A4A4A;
  font-size: 26rpx;
  line-height: 1.7;
}

.info-list {
  padding: 24rpx 34rpx 8rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F0F4FA;
  color: #1A1A1A;
  font-size: 27rpx;
  line-height: 1.55;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-icon {
  flex: 0 0 auto;
  width: 44rpx;
  margin-right: 12rpx;
  color: #C9A227;
  font-size: 32rpx;
  line-height: 1.55;
}

.manager-actions {
  display: flex;
  padding: 16rpx 34rpx 34rpx;
}

.manager-action {
  flex: 1;
  height: 78rpx;
  border: 1rpx solid #E5E5E5;
  border-radius: 39rpx;
  background: #FFFFFF;
  color: #8C8C8C;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 76rpx;
}

.manager-action::after,
.staff-bind-button::after {
  border: 0;
}

.manager-action.primary {
  border-color: transparent;
  color: #FFFFFF;
  background: linear-gradient(135deg, #E6B84E, #C9A227);
  box-shadow: 0 6rpx 16rpx rgba(201, 162, 39, 0.2);
}

.manager-action + .manager-action {
  margin-left: 18rpx;
}

.qrcode-card {
  display: flex;
  align-items: center;
  margin: 0 34rpx 34rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(201, 162, 39, 0.1);
  border-radius: 24rpx;
  background:
    linear-gradient(120deg, rgba(201, 162, 39, 0.06), transparent 42%),
    #FFFDF9;
}

.qrcode-image {
  width: 132rpx;
  height: 132rpx;
  border: 1rpx solid #E5E5E5;
  border-radius: 20rpx;
  background: #FFFFFF;
  box-shadow: 0 10rpx 28rpx rgba(15, 35, 70, 0.05);
}

.qrcode-text {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
  color: #1A1A1A;
  font-size: 28rpx;
  font-weight: 700;
}

.qrcode-text text {
  display: block;
  margin-top: 8rpx;
  color: #8C8C8C;
  font-size: 24rpx;
  font-weight: 400;
}

.state-card {
  padding: 56rpx 34rpx;
  text-align: center;
}

.state-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  margin: 0 auto 24rpx;
  border-radius: 28rpx;
  background: #FFF9E6;
  color: #C9A227;
  font-size: 28rpx;
  font-weight: 800;
}

@keyframes pulse {
  0% {
    transform: scale(0.85);
    opacity: 0.6;
  }
  50% {
    transform: scale(1.15);
    opacity: 1;
  }
  100% {
    transform: scale(0.85);
    opacity: 0.6;
  }
}

.loading-dot::after {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E6B84E, #C9A227);
  content: '';
  animation: pulse 1.6s infinite ease-in-out;
}

.state-title {
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.4;
}

.state-desc {
  margin-top: 14rpx;
  color: #8C8C8C;
  font-size: 26rpx;
  line-height: 1.6;
}

.staff-bind-card {
  padding-bottom: 40rpx;
}

.staff-bind-field {
  margin: 42rpx 32rpx 0;
}

.staff-bind-label {
  color: #1A1A1A;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.staff-bind-input {
  box-sizing: border-box;
  width: 100%;
  height: 92rpx;
  margin-top: 18rpx;
  padding: 0 24rpx;
  border: 1rpx solid #E5E5E5;
  border-radius: 20rpx;
  background: #F5F3F0;
  color: #1A1A1A;
  font-size: 32rpx;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.72);
  transition: all 0.25s ease;
}

.staff-bind-input:focus {
  border-color: #C9A227;
  background: #FFFFFF;
  box-shadow: 0 0 12rpx rgba(201, 162, 39, 0.12);
}

.staff-bind-button {
  height: 88rpx;
  margin: 44rpx 32rpx 0;
  border-radius: 44rpx;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
  background: linear-gradient(135deg, #E6B84E, #C9A227);
  box-shadow: 0 6rpx 16rpx rgba(201, 162, 39, 0.2);
  transition: all 0.2s ease;
}

.staff-bind-button[disabled] {
  color: #FFFFFF;
  background: #BCC6D6;
  box-shadow: none;
  opacity: 1;
}

.button-hover {
  transform: scale(0.98);
  opacity: 0.9;
}

.card-hover {
  transform: scale(0.99);
  opacity: 0.95;
}

.staff-bind-note {
  margin: 24rpx 32rpx 0;
  color: #8C8C8C;
  font-size: 24rpx;
  line-height: 1.6;
  text-align: center;
}

.store-section {
  margin-top: 28rpx;
  padding: 28rpx 32rpx 12rpx;
  border: 1rpx solid rgba(201, 162, 39, 0.08);
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.store-section-head {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.store-section-icon {
  margin-right: 12rpx;
  color: #C9A227;
  font-size: 34rpx;
}

.store-section-title {
  color: #1A1A1A;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.4;
}

.store-empty {
  padding: 32rpx 0;
  color: #A6A6A6;
  font-size: 26rpx;
  text-align: center;
}

.store-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #F0F4FA;
}

.store-item:last-child {
  border-bottom: 0;
}

.store-name {
  position: relative;
  padding-left: 22rpx;
  color: #1A1A1A;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
}

.store-name::before {
  position: absolute;
  left: 0;
  top: 12rpx;
  width: 8rpx;
  height: 24rpx;
  border-radius: 4rpx;
  background: linear-gradient(135deg, #E6B84E, #C9A227);
  content: '';
}

.store-meta {
  display: flex;
  align-items: flex-start;
  margin-top: 10rpx;
  padding-left: 22rpx;
}

.store-meta-icon {
  flex: 0 0 auto;
  width: 32rpx;
  margin-right: 8rpx;
  color: #C9A227;
  font-size: 26rpx;
  line-height: 1.6;
}

.store-meta-text {
  flex: 1;
  min-width: 0;
  color: #8C8C8C;
  font-size: 25rpx;
  line-height: 1.6;
}
