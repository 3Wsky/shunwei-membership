/* ---------------------------------------------------------------- */
/* 【UX/UI 视觉与交互设计师】 兑换订单详情页 极致轻奢风重构 (对齐 24_UI) */
/* ---------------------------------------------------------------- */

page {
  background: linear-gradient(180deg, #F7FBFF 0%, #EEF5FF 100%) !important;
  min-height: 100vh;
}

/* 1. 顶部状态 Banner 区：深蓝奢华渐变 */
.order-details .header.data-v-4aac0955 {
  background: linear-gradient(135deg, #1A1F36 0%, #2D3561 100%) !important;
  height: 160rpx !important;
  display: flex !important;
  align-items: center !important;
  padding: 0 40rpx !important;
  box-sizing: border-box !important;
}

.order-details .header .pictrue.data-v-4aac0955 {
  width: 100rpx !important;
  height: 100rpx !important;
}

.order-details .header .data.data-v-4aac0955 {
  color: rgba(255, 255, 255, 0.8) !important;
  font-size: 24rpx !important;
  margin-left: 24rpx !important;
}

.order-details .header .data .state.data-v-4aac0955 {
  font-size: 32rpx !important;
  font-weight: 800 !important;
  color: #ffffff !important;
  margin-bottom: 6rpx !important;
}

/* 2. 收货地址区：白色悬浮卡片 */
.order-details .address.data-v-4aac0955 {
  margin: 24rpx 32rpx !important;
  padding: 32rpx !important;
  border-radius: 24rpx !important;
  background: #FFFFFF !important;
  border: 1rpx solid rgba(230, 238, 248, 0.9) !important;
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.04) !important;
  box-sizing: border-box !important;
}

.order-details .address .name.data-v-4aac0955 {
  font-size: 30rpx !important;
  color: #0B1F3A !important;
  font-weight: 700 !important;
  margin-bottom: 12rpx !important;
}

.order-details .address .name .phone.data-v-4aac0955 {
  margin-left: 32rpx !important;
  color: #8A95A6 !important;
  font-size: 26rpx !important;
  font-weight: 400 !important;
}

.order-details .line.data-v-4aac0955 {
  display: none !important; /* 隐藏传统的锯齿分割线 */
}

/* 3. 商品详情区：精致 Bento 圆角白卡 */
.orderGoods.data-v-4aac0955 {
  background-color: #FFFFFF !important;
  margin: 24rpx 32rpx !important;
  border-radius: 24rpx !important;
  border: 1rpx solid rgba(230, 238, 248, 0.9) !important;
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.04) !important;
  overflow: hidden !important;
}

.orderGoods .total.data-v-4aac0955 {
  width: 100% !important;
  height: 88rpx !important;
  padding: 0 28rpx !important;
  border-bottom: 1rpx solid #F0F4FA !important;
  font-size: 28rpx !important;
  color: #0B1F3A !important;
  font-weight: 700 !important;
  line-height: 88rpx !important;
  box-sizing: border-box !important;
}

.orderGoods .goodWrapper.data-v-4aac0955 {
  padding: 0 !important;
}

.orderGoods .goodWrapper .item.data-v-4aac0955 {
  padding: 28rpx !important;
  display: flex !important;
  align-items: center !important;
}

/* 商品大图 */
.orderGoods .goodWrapper .item .pictrue.data-v-4aac0955 {
  width: 120rpx !important;
  height: 120rpx !important;
  flex-shrink: 0 !important;
}

.orderGoods .goodWrapper .item .pictrue image.data-v-4aac0955 {
  width: 100% !important;
  height: 100% !important;
  border-radius: 16rpx !important;
  border: 1rpx solid rgba(0, 0, 0, 0.03) !important;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04) !important;
}

/* 商品文字与积分高亮 */
.orderGoods .goodWrapper .item .text.data-v-4aac0955 {
  flex: 1 !important;
  min-width: 0 !important;
  margin-left: 24rpx !important;
}

.orderGoods .goodWrapper .item .text .name.data-v-4aac0955 {
  color: #0B1F3A !important;
  font-weight: 700 !important;
  font-size: 28rpx !important;
}

.orderGoods .goodWrapper .item .text .attr.data-v-4aac0955 {
  color: #8A95A6 !important;
  font-size: 22rpx !important;
  margin-top: 8rpx !important;
}

.orderGoods .goodWrapper .item .text .money.data-v-4aac0955 {
  color: #B8862B !important; /* 金色重点 */
  font-weight: 800 !important;
  font-size: 32rpx !important;
  margin-top: 10rpx !important;
}

/* 4. 激活的“礼品核销码卡”：金辉设计 */
.order-details .writeOff.data-v-4aac0955 {
  background-color: #FFFFFF !important;
  margin: 24rpx 32rpx !important;
  border-radius: 24rpx !important;
  border: 1rpx solid rgba(201, 162, 39, 0.15) !important;
  box-shadow: 0 12rpx 36rpx rgba(201, 162, 39, 0.06) !important;
  overflow: hidden !important;
  padding-bottom: 32rpx !important;
}

.order-details .writeOff .title.data-v-4aac0955 {
  font-size: 28rpx !important;
  color: #8C6D16 !important;
  font-weight: 700 !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  border-bottom: 1rpx solid rgba(201, 162, 39, 0.1) !important;
  padding: 0 28rpx !important;
  background: linear-gradient(135deg, #FBF8F5, #FFFDF9) !important;
}

/* 灰底高档扫码盒 */
.order-details .writeOff .grayBg.data-v-4aac0955 {
  background-color: #F7F9FC !important;
  width: 590rpx !important;
  height: 384rpx !important;
  border-radius: 20rpx 20rpx 0 0 !important;
  margin: 40rpx auto 0 auto !important;
  padding-top: 48rpx !important;
  box-sizing: border-box !important;
}

.order-details .writeOff .grayBg .pictrue.data-v-4aac0955 {
  width: 290rpx !important;
  height: 290rpx !important;
  margin: 0 auto !important;
}

/* 隐藏 CRMEB 原生齿轮装饰图（灰盒与金码已直接相连，齿轮多余且未对齐） */
.order-details .writeOff .gear.data-v-4aac0955 {
  display: none !important;
}

/* 金底黑字核销码 */
.order-details .writeOff .num.data-v-4aac0955 {
  background-color: #F0C34C !important;
  width: 590rpx !important;
  height: 84rpx !important;
  line-height: 84rpx !important;
  color: #282828 !important;
  font-size: 42rpx !important;
  font-weight: 900 !important;
  margin: 0 auto !important;
  border-radius: 0 0 20rpx 20rpx !important;
  text-align: center !important;
  padding-top: 0 !important;
  letter-spacing: 4rpx !important;
  box-shadow: 0 4rpx 12rpx rgba(240, 195, 76, 0.2) !important;
}

/* 使用说明区：核销码下方提示卡 */
.order-details .writeOff .rules.data-v-4aac0955 {
  margin: 28rpx 28rpx 0 28rpx !important;
  padding: 24rpx 28rpx !important;
  background: #FBF8F2 !important;
  border: 1rpx solid rgba(201, 162, 39, 0.12) !important;
  border-radius: 16rpx !important;
}

.order-details .writeOff .rules .item.data-v-4aac0955 {
  display: block !important;
}

.order-details .writeOff .rules .rulesTitle.data-v-4aac0955 {
  display: flex !important;
  align-items: center !important;
  font-size: 26rpx !important;
  font-weight: 700 !important;
  color: #8C6D16 !important;
  margin-bottom: 10rpx !important;
}

.order-details .writeOff .rules .rulesTitle .iconfont.data-v-4aac0955 {
  margin-right: 10rpx !important;
  font-size: 28rpx !important;
  color: #C9A227 !important;
}

.order-details .writeOff .rules .info.data-v-4aac0955 {
  font-size: 24rpx !important;
  color: #8A7A52 !important;
  line-height: 38rpx !important;
}

/* 5. 订单信息参数列表 */
.order-details .wrapper.data-v-4aac0955 {
  background-color: #FFFFFF !important;
  margin: 24rpx 32rpx !important;
  padding: 32rpx !important;
  border-radius: 24rpx !important;
  border: 1rpx solid rgba(230, 238, 248, 0.9) !important;
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.04) !important;
  box-sizing: border-box !important;
}

.order-details .wrapper .item.data-v-4aac0955 {
  font-size: 26rpx !important;
  color: #8A95A6 !important;
  font-weight: 400 !important;
  display: flex !important;
  justify-content: space-between !important;
  align-items: center !important;
}

.order-details .wrapper .item .conter.data-v-4aac0955 {
  color: #0B1F3A !important;
  font-weight: 700 !important;
  font-size: 26rpx !important;
}

/* 一键复制按钮胶囊化 */
.order-details .wrapper .item .conter .copy.data-v-4aac0955 {
  font-size: 20rpx !important;
  color: #1F6BFF !important;
  border-radius: 8rpx !important;
  border: 1rpx solid rgba(31, 107, 255, 0.2) !important;
  background: #EEF5FF !important;
  padding: 2rpx 12rpx !important;
  margin-left: 16rpx !important;
  display: inline-block !important;
}

/* 6. 底部操作按钮区 */
.order-details .footer.data-v-4aac0955 {
  height: 100rpx !important;
  background-color: #FFFFFF !important;
  border-top: 1rpx solid #F0F4FA !important;
  padding: 0 32rpx !important;
  box-sizing: border-box !important;
}

.order-details .footer .bnt.data-v-4aac0955 {
  width: 176rpx !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  border-radius: 32rpx !important;
  font-size: 26rpx !important;
  font-weight: 700 !important;
  transition: all 0.2s ease !important;
}

.order-details .footer .bnt.cancel.data-v-4aac0955 {
  color: #8A95A6 !important;
  background: #FFFFFF !important;
  border: 1rpx solid #E6EEF8 !important;
}

.order-details .footer .bnt.bg-color.data-v-4aac0955 {
  background: linear-gradient(135deg, #4D9BFF, #1F6BFF) !important;
  color: #ffffff !important;
  box-shadow: 0 4rpx 12rpx rgba(31, 107, 255, 0.2) !important;
  border: none !important;
}

.order-details .footer .bnt ~ .bnt.data-v-4aac0955 {
  margin-left: 18rpx !important;
}

.order-details .footer .bnt:active {
  transform: scale(0.96) !important;
  opacity: 0.9 !important;
}
