/* 锦程积分商城 · 入场切屏过渡（轻奢金） */
page{background:#1a1410}
.jc-portal{position:fixed;left:0;top:0;right:0;bottom:0;display:flex;align-items:center;justify-content:center;overflow:hidden;background:radial-gradient(120% 80% at 50% 30%, #2a2118 0%, #1a1410 55%, #100c08 100%)}
.jc-portal-glow{position:absolute;width:560rpx;height:560rpx;border-radius:50%;background:radial-gradient(circle, rgba(201,162,39,0.28) 0%, rgba(201,162,39,0.08) 45%, rgba(201,162,39,0) 70%);filter:blur(2rpx);animation:jcPulse 2.2s ease-in-out infinite}
.jc-portal-card{position:relative;display:flex;flex-direction:column;align-items:center;animation:jcRise 0.5s cubic-bezier(0.16,0.84,0.44,1) both}
.jc-portal-ring{width:160rpx;height:160rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;background:conic-gradient(from 0deg, rgba(201,162,39,0) 0deg, #C9A227 120deg, #F0D27A 200deg, rgba(201,162,39,0) 320deg);animation:jcSpin 1.1s linear infinite}
.jc-portal-ring-core{width:128rpx;height:128rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg, #2a2118 0%, #16110b 100%);box-shadow:inset 0 2rpx 12rpx rgba(0,0,0,0.5)}
.jc-portal-ring-core .iconfont{font-size:64rpx;background:linear-gradient(135deg,#F0D27A 0%,#C9A227 100%);-webkit-background-clip:text;background-clip:text;color:transparent}
.jc-portal-title{margin-top:44rpx;font-size:38rpx;font-weight:700;letter-spacing:4rpx;background:linear-gradient(90deg,#F6E3A6 0%,#C9A227 50%,#F6E3A6 100%);-webkit-background-clip:text;background-clip:text;color:transparent}
.jc-portal-sub{margin-top:16rpx;font-size:24rpx;color:rgba(240,210,122,0.55);letter-spacing:1rpx}
.jc-portal-dots{margin-top:36rpx;display:flex;align-items:center}
.jc-portal-dots .d{width:12rpx;height:12rpx;border-radius:50%;margin:0 8rpx;background:#C9A227;opacity:0.3;animation:jcDot 1.2s ease-in-out infinite}
.jc-portal-dots .d2{animation-delay:0.2s}
.jc-portal-dots .d3{animation-delay:0.4s}
@keyframes jcSpin{to{transform:rotate(360deg)}}
@keyframes jcPulse{0%,100%{transform:scale(0.92);opacity:0.7}50%{transform:scale(1.08);opacity:1}}
@keyframes jcRise{0%{opacity:0;transform:translateY(28rpx) scale(0.96)}100%{opacity:1;transform:translateY(0) scale(1)}}
@keyframes jcDot{0%,100%{opacity:0.3;transform:translateY(0)}50%{opacity:1;transform:translateY(-8rpx)}}
