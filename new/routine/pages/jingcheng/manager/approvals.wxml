<view class="page">
  <view wx:for="{{list}}" wx:key="requestId" class="card">
    <view class="card-head">
      <view class="ch-left">
        <view class="ch-icon"><text class="iconfont icon-liebiao2"></text></view>
        <text class="ch-title">申请单 #{{item.requestId}}</text>
      </view>
      <view class="ch-status"><text class="dot"></text>待店长审批</view>
    </view>

    <view class="row">
      <view class="row-label"><text class="iconfont icon-yonghu"></text>会员</view>
      <view class="row-value-container">
        <text class="row-name">{{item.customerName || '未知'}}</text>
        <text class="uid-tag">UID {{item.customerUid}}</text>
      </view>
    </view>
    <view class="row">
      <view class="row-label"><text class="iconfont icon-yonghu2"></text>申请店员</view>
      <view class="row-value-container">
        <text class="row-name">{{item.clerkName || '未知'}}</text>
        <text class="uid-tag">UID {{item.clerkUid}}</text>
      </view>
    </view>
    <view class="row">
      <view class="row-label"><text class="iconfont icon-liwu"></text>产品信息</view>
      <text class="row-value {{item.hasProduct ? '' : 'muted'}}">{{item.productText}}</text>
    </view>

    <view class="benefit">
      <view class="benefit-seg"><text class="iconfont icon-yue2"></text>{{item.rangeText}}</view>
      <view class="benefit-seg"><text class="iconfont icon-jifenshangcheng"></text>{{item.matchedIntegral}} 积分</view>
      <view class="benefit-seg"><text class="iconfont icon-shoudanyouhui"></text>￥{{item.matchedVoucher}} 现金券</view>
    </view>

    <view class="buttons">
      <button class="reject" data-index="{{index}}" data-action="reject" bindtap="review">驳回</button>
      <button class="approve" data-index="{{index}}" data-action="approve" bindtap="review">通过</button>
    </view>
  </view>

  <view wx:if="{{!loading && !list.length}}" class="empty">
    <view class="empty-icon"><text class="iconfont icon-liebiao2"></text></view>
    <view>暂无待审批申请</view>
  </view>
</view>
