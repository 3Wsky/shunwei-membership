.page{min-height:100vh;background:#f5f3f0;padding:24rpx;box-sizing:border-box}.card{background:#fff;border-radius:20rpx;padding:26rpx;margin-bottom:18rpx}.head,.row{display:flex;justify-content:space-between}.head{font-size:28rpx;font-weight:600;color:#1a1f36;padding-bottom:20rpx;border-bottom:1rpx solid #eee}.pending{font-size:23rpx;color:#b48b16}.row{font-size:25rpx;color:#777;padding-top:18rpx}.row text:last-child{color:#333}.benefit{display:flex;justify-content:space-between;background:#f8f6f1;margin-top:22rpx;padding:20rpx;border-radius:14rpx;color:#8d6d16;font-size:24rpx}.buttons{display:flex;gap:18rpx;margin-top:24rpx}.buttons button{flex:1;font-size:27rpx}.reject{background:#fff;color:#b54a4a;border:1rpx solid #e4bcbc}.approve{background:#1a1f36;color:#d8bc61}.empty{text-align:center;padding:100rpx 0;color:#999}
