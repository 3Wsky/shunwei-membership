page {
  background: #F5F3F0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 56rpx;
  box-sizing: border-box;
  color: #1A1A1A;
  background: #F5F3F0;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(201, 162, 39, 0.08);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 22rpx;
  border-bottom: 1rpx solid #F0F4FA;
}

.ch-left {
  display: flex;
  align-items: center;
}

.ch-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  color: #fff;
  background: linear-gradient(135deg, #E6B84E, #C9A227);
}

.ch-icon .iconfont {
  font-size: 30rpx;
}

.ch-title {
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 900;
}

.ch-status {
  display: flex;
  align-items: center;
  color: #C9A227;
  font-size: 24rpx;
  font-weight: 700;
}

.ch-status .dot {
  width: 12rpx;
  height: 12rpx;
  margin-right: 10rpx;
  border-radius: 50%;
  background: #C9A227;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 22rpx;
}

.row-label {
  display: flex;
  align-items: center;
  color: #8C8C8C;
  font-size: 26rpx;
}

.row-label .iconfont {
  margin-right: 12rpx;
  color: #C9A227;
  font-size: 30rpx;
}

.row-value {
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #1A1A1A;
  font-size: 27rpx;
  font-weight: 700;
  text-align: right;
}

.row-value.muted {
  color: #B6BECB;
  font-weight: 400;
}

.benefit {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 20rpx 12rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #FBF8F5, #FFFDF9);
  border: 1rpx solid rgba(201, 162, 39, 0.15);
}

.benefit-seg {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8D6D16;
  font-size: 23rpx;
  font-weight: 700;
}

.benefit-seg + .benefit-seg {
  border-left: 1rpx solid rgba(201, 162, 39, 0.15);
}

.benefit-seg .iconfont {
  margin-right: 8rpx;
  font-size: 26rpx;
}

.buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 26rpx;
}

.buttons button {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.buttons button::after {
  border: none;
}

.reject {
  color: #E34D59;
  background: #fff;
  border: 1rpx solid #F3B4BA;
}

.approve {
  color: #fff;
  background: linear-gradient(135deg, #E6B84E, #C9A227);
  box-shadow: 0 6rpx 16rpx rgba(201, 162, 39, 0.2);
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #8C8C8C;
  font-size: 27rpx;
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  border-radius: 36rpx;
  color: #D4AF37;
  background: linear-gradient(145deg, #FFF9E6, #FFF0CC);
}

.empty-icon .iconfont {
  font-size: 60rpx;
}

.row-value-container {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  max-width: 70%;
}

.row-name {
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #1A1A1A;
  font-size: 27rpx;
  font-weight: 700;
  text-align: right;
}

.uid-tag {
  font-size: 20rpx;
  color: #C9A227;
  background: rgba(201, 162, 39, 0.08);
  border: 1rpx solid rgba(201, 162, 39, 0.15);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
  font-weight: 700;
  white-space: nowrap;
  flex-shrink: 0;
}
