page {
  min-height: 100%;
  background: #F5F3F0;
}

.activity-page {
  min-height: 100vh;
  padding: 0 0 60rpx;
  box-sizing: border-box;
  color: #1A1A1A;
  background: #F5F3F0;
}

.activity-hero {
  position: relative;
  overflow: hidden;
  padding: 48rpx 40rpx 56rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #1A1F36 0%, #2D3561 100%);
}

.hero-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  margin-bottom: 24rpx;
  border-radius: 26rpx;
  color: #E6B84E;
  font-size: 48rpx;
  background: rgba(230, 184, 78, 0.16);
}

.hero-title {
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.4;
}

.hero-sub {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
}

.hero-date {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.55);
  font-size: 22rpx;
}

.activity-notice {
  margin: 28rpx 32rpx 0;
  padding: 24rpx 28rpx;
  border: 1rpx solid rgba(230, 184, 78, 0.35);
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(230, 184, 78, 0.12), rgba(201, 162, 39, 0.06));
}

.notice-tag {
  display: inline-block;
  margin-right: 12rpx;
  padding: 2rpx 14rpx;
  border-radius: 8rpx;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #E6B84E, #C9A227);
}

.notice-text {
  color: #6B5114;
  font-size: 25rpx;
  line-height: 1.7;
}

.pool-card {
  margin: 28rpx 32rpx 0;
  padding: 30rpx 32rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #1A1F36 0%, #2D3561 100%);
  box-shadow: 0 6rpx 24rpx rgba(26, 31, 54, 0.18);
}

.pool-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.pool-title {
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 800;
}

.pool-level {
  padding: 4rpx 18rpx;
  border-radius: 20rpx;
  color: #1A1F36;
  font-size: 22rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #E6B84E, #C9A227);
}

.pool-bar {
  position: relative;
  height: 28rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.12);
}

.pool-bar-issued {
  height: 100%;
  border-radius: 16rpx;
  background: linear-gradient(90deg, #E6B84E, #C9A227);
  transition: width 0.6s ease;
}

/* 额度偏紧/告急时进度条转暖色，仍不显示数字 */
.pool-tight .pool-bar-issued {
  background: linear-gradient(90deg, #F5A623, #ED7B2F);
}

.pool-low .pool-bar-issued {
  background: linear-gradient(90deg, #FF6A6A, #E34D59);
}

.pool-legend {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
}

.pl-item {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
}

.pl-dot {
  width: 18rpx;
  height: 18rpx;
  margin-right: 10rpx;
  border-radius: 50%;
}

.pl-dot-issued {
  background: linear-gradient(135deg, #E6B84E, #C9A227);
}

.pl-dot-remain {
  background: rgba(255, 255, 255, 0.25);
}

.pl-label {
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
}

.pool-tip {
  margin-top: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  font-size: 22rpx;
  line-height: 1.6;
}

.section-card {
  margin: 28rpx 32rpx 0;
  padding: 30rpx 32rpx 12rpx;
  border: 1rpx solid rgba(201, 162, 39, 0.08);
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.section-head {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.section-bar {
  width: 8rpx;
  height: 30rpx;
  margin-right: 14rpx;
  border-radius: 4rpx;
  background: linear-gradient(135deg, #E6B84E, #C9A227);
}

.section-title {
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.4;
}

.section-line {
  padding: 12rpx 0;
  color: #4A4A4A;
  font-size: 27rpx;
  line-height: 1.8;
  text-align: justify;
}

.activity-foot {
  margin: 36rpx 40rpx 0;
  color: #A6A6A6;
  font-size: 24rpx;
  line-height: 1.7;
  text-align: center;
}
