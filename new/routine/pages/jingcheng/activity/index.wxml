<view class="activity-page">
  <view class="activity-hero">
    <view class="hero-badge"><text class="iconfont icon-tishi"></text></view>
    <view class="hero-title">{{activityName}}</view>
    <view class="hero-sub">活动说明与免责条款</view>
    <view wx:if="{{updatedAt}}" class="hero-date">更新时间：{{updatedAt}}</view>
  </view>

  <view wx:for="{{sections}}" wx:key="title" class="section-card">
    <view class="section-head">
      <text class="section-bar"></text>
      <text class="section-title">{{item.title}}</text>
    </view>
    <view class="section-body">
      <view wx:for="{{item.items}}" wx:for-item="line" wx:for-index="lineIdx" wx:key="lineIdx" class="section-line">{{line}}</view>
    </view>
  </view>

  <view class="activity-foot">如对活动有疑问，请咨询您的专属客户经理或到店了解。</view>
</view>
