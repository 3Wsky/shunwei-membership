<view class="activity-page">
  <view class="activity-hero">
    <view class="hero-badge"><text class="iconfont icon-tishi"></text></view>
    <view class="hero-title">{{activityName}}</view>
    <view wx:if="{{subTitle}}" class="hero-sub">{{subTitle}}</view>
    <view wx:if="{{updatedAt}}" class="hero-date">更新时间：{{updatedAt}}</view>
  </view>

  <view wx:if="{{notice}}" class="activity-notice">
    <text class="notice-tag">重要提示</text>
    <text class="notice-text">{{notice}}</text>
  </view>

  <view wx:if="{{poolReady}}" class="pool-card pool-{{poolLevel}}">
    <view class="pool-head">
      <text class="pool-title">消费券发放进度</text>
      <text wx:if="{{poolLevelText}}" class="pool-level">{{poolLevelText}}</text>
    </view>
    <view class="pool-bar">
      <view class="pool-bar-issued" style="width:{{issuedPercent}}%"></view>
    </view>
    <view class="pool-legend">
      <view class="pl-item"><text class="pl-dot pl-dot-issued"></text><text class="pl-label">已发放</text></view>
      <view class="pl-item"><text class="pl-dot pl-dot-remain"></text><text class="pl-label">剩余额度</text></view>
    </view>
    <view class="pool-tip">数量有限 · 发完即止（仅展示发放进度，不代表具体金额）</view>
  </view>

  <view wx:for="{{sections}}" wx:key="title" class="section-card">
    <view class="section-head">
      <text class="section-bar"></text>
      <text class="section-title">{{item.title}}</text>
    </view>
    <view class="section-body">
      <view wx:for="{{item.items}}" wx:for-item="line" wx:for-index="lineIdx" wx:key="lineIdx" class="section-line">{{line}}</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="activity-foot">内容加载中…</view>
  <view wx:else class="activity-foot">如对活动有疑问，请咨询您的专属客户经理或到店了解。</view>
</view>
