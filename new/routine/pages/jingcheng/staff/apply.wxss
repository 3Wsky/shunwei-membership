.page{min-height:100vh;background:#f5f3f0;padding:24rpx;box-sizing:border-box}.member{display:flex;align-items:center;background:#1a1f36;color:#fff;padding:28rpx;border-radius:20rpx}.member image{width:92rpx;height:92rpx;border-radius:50%;margin-right:22rpx}.name{font-size:31rpx;font-weight:600}.meta{font-size:23rpx;color:#c6c9d6;margin-top:9rpx}.assets{display:flex;background:#fff;border-radius:18rpx;margin-top:18rpx;padding:24rpx}.assets view{width:50%;display:flex;flex-direction:column;align-items:center}.assets view+view{border-left:1rpx solid #eee}.assets text{font-size:34rpx;color:#b48b16;font-weight:700}.assets label{font-size:23rpx;color:#999;margin-top:6rpx}.heading{font-size:29rpx;font-weight:600;color:#252a3d;margin:32rpx 6rpx 18rpx}.rule{position:relative;background:#fff;border-radius:18rpx;padding:24rpx;margin-bottom:16rpx;border-left:6rpx solid #c9a227}.range{font-size:24rpx;color:#888}.tier{font-size:32rpx;font-weight:700;color:#1a1f36;margin-top:8rpx}.gift{display:flex;gap:26rpx;margin-top:14rpx;color:#9b7715;font-size:24rpx}.select{position:absolute;right:24rpx;top:50%;color:#b48b16;font-size:25rpx}.tip{padding:22rpx;color:#999;font-size:23rpx;line-height:1.7}
