page {
  background: #F5F3F0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 56rpx;
  box-sizing: border-box;
  color: #1A1A1A;
  background: #F5F3F0;
}

/* Profile card */
.profile {
  padding: 30rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #1A1F36 0%, #2D3561 100%);
  box-shadow: 0 12rpx 36rpx rgba(26, 31, 54, 0.16);
}

.profile-top {
  display: flex;
  align-items: center;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.profile-info {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.profile-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #fff;
  font-size: 36rpx;
  font-weight: 900;
}

.profile-meta {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.75);
  font-size: 23rpx;
}

.profile-badge {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  color: #2A2207;
  font-size: 22rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #F8DC8E, #E6B84E);
}

.profile-badge .iconfont {
  margin-right: 6rpx;
  font-size: 24rpx;
}

.assets {
  display: flex;
  margin-top: 26rpx;
  padding: 26rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.asset-cell {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.asset-cell + .asset-cell {
  border-left: 1rpx solid #EAEFF6;
  padding-left: 28rpx;
}

.asset-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  height: 70rpx;
  flex: 0 0 70rpx;
  margin-right: 18rpx;
  border-radius: 20rpx;
}

.asset-icon.blue {
  color: #C9A227;
  background: linear-gradient(145deg, #FFF9E6, #FFF0CC);
}

.asset-icon.gold {
  color: #C9A227;
  background: linear-gradient(145deg, #FFF9E6, #FFF0CC);
}

.asset-icon .iconfont {
  font-size: 38rpx;
}

.asset-value {
  color: #1A1A1A;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
}

.asset-value.gold {
  color: #C9A227;
}

.asset-label {
  margin-top: 8rpx;
  color: #8C8C8C;
  font-size: 22rpx;
}

/* Heading */
.heading {
  display: flex;
  align-items: center;
  margin: 34rpx 4rpx 20rpx;
  padding-left: 18rpx;
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 900;
  border-left: 8rpx solid #C9A227;
}

/* Tier grid */
.tier-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 22rpx;
}

.tier-card {
  width: calc(50% - 11rpx);
  box-sizing: border-box;
  padding: 26rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(201, 162, 39, 0.15);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.tier-range {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 14rpx;
  color: #8C7355;
  font-size: 22rpx;
  font-weight: 700;
  background: #FBF8F5;
}

.tier-integral {
  margin-top: 22rpx;
  color: #C9A227;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
}

.tier-integral text {
  margin-left: 6rpx;
  color: #C9A227;
  font-size: 24rpx;
  font-weight: 700;
}

.tier-voucher {
  margin-top: 14rpx;
  padding-bottom: 22rpx;
  border-bottom: 1rpx dashed #E2E8F1;
  color: #C9A227;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
}

.tier-voucher text {
  margin-left: 6rpx;
  color: #C9A227;
  font-size: 24rpx;
  font-weight: 700;
}

.tier-btn {
  margin-top: 22rpx;
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  border-radius: 18rpx;
  color: #fff;
  font-size: 27rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #E6B84E, #C9A227);
  box-shadow: 0 6rpx 16rpx rgba(201, 162, 39, 0.2);
}

.tip {
  display: flex;
  align-items: center;
  margin: 30rpx 4rpx 0;
  color: #8C8C8C;
  font-size: 23rpx;
}

.tip .iconfont {
  margin-right: 10rpx;
  color: #C9A227;
  font-size: 28rpx;
}

/* Modal */
.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: flex-end;
  background: rgba(11, 22, 45, 0.6);
}

.modal {
  width: 100%;
  padding: 34rpx 36rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  border-radius: 36rpx 36rpx 0 0;
  background: #FFFFFF;
}

.modal-head {
  display: flex;
  align-items: center;
}

.modal-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  flex: 0 0 78rpx;
  margin-right: 20rpx;
  border-radius: 22rpx;
  color: #C9A227;
  background: linear-gradient(145deg, #FFF9E6, #FFF0CC);
}

.modal-icon .iconfont {
  font-size: 42rpx;
}

.modal-head-text {
  flex: 1;
  min-width: 0;
}

.modal-title {
  color: #1A1A1A;
  font-size: 34rpx;
  font-weight: 900;
}

.modal-sub {
  margin-top: 8rpx;
  color: #8C8C8C;
  font-size: 23rpx;
}

.modal-close {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  color: #8C8C8C;
  background: #F5F5F5;
}

.modal-close .iconfont {
  font-size: 28rpx;
}

.field-label {
  margin: 28rpx 0 14rpx;
  color: #1A1A1A;
  font-size: 26rpx;
  font-weight: 700;
}

.type-row {
  display: flex;
  gap: 18rpx;
}

.type-chip {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 18rpx;
  color: #4A4A4A;
  font-size: 27rpx;
  font-weight: 700;
  background: #F5F5F5;
  border: 1rpx solid #E5E5E5;
}

.type-chip.active {
  color: #C9A227;
  background: #FFF9E6;
  border: 1rpx solid #C9A227;
}

.field-input {
  height: 92rpx;
  padding: 0 26rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  background: #F5F5F5;
  border: 1rpx solid #E5E5E5;
  box-sizing: border-box;
}

.ph {
  color: #B6BECB;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
}

.modal-btn {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  border-radius: 46rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.modal-btn.cancel {
  color: #8C8C8C;
  background: #F5F5F5;
  border: 1rpx solid #E5E5E5;
}

.modal-btn.submit {
  color: #fff;
  background: linear-gradient(135deg, #1A1F36 0%, #2D3561 100%);
  box-shadow: 0 8rpx 24rpx rgba(26, 31, 54, 0.2);
}

.modal-btn.submit.disabled {
  opacity: 0.6;
}

.modal-tip {
  margin-top: 22rpx;
  text-align: center;
  color: #8C8C8C;
  font-size: 22rpx;
}

.scan-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, rgba(230, 184, 78, 0.08), rgba(230, 184, 78, 0.02));
  border: 1rpx solid rgba(230, 184, 78, 0.2);
}

.scan-tip {
  font-size: 24rpx;
  color: #8C7640;
}

.scan-btn-sm {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #E6B84E, #C9A227);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.scan-btn-sm .iconfont {
  margin-right: 8rpx;
  font-size: 26rpx;
}

.scan-btn-sm.disabled {
  opacity: 0.5;
}

.field-input.mono {
  font-family: 'Courier New', Consolas, monospace;
  letter-spacing: 2rpx;
}
