page {
  background: linear-gradient(180deg, #F7FBFF 0%, #EEF5FF 100%);
}

.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 56rpx;
  box-sizing: border-box;
  color: #0B1F3A;
  background:
    radial-gradient(circle at 82% 6%, rgba(77, 155, 255, 0.14), transparent 260rpx),
    linear-gradient(180deg, #F7FBFF 0%, #EEF5FF 100%);
}

/* Profile card */
.profile {
  padding: 30rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #2F6BEA, #1E54D6);
  box-shadow: 0 16rpx 38rpx rgba(31, 84, 224, 0.28);
}

.profile-top {
  display: flex;
  align-items: center;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.profile-info {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.profile-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #fff;
  font-size: 36rpx;
  font-weight: 900;
}

.profile-meta {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 23rpx;
}

.profile-badge {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  color: #5A4310;
  font-size: 22rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #F8DC8E, #E6B84E);
}

.profile-badge .iconfont {
  margin-right: 6rpx;
  font-size: 24rpx;
}

.assets {
  display: flex;
  margin-top: 26rpx;
  padding: 26rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.96);
}

.asset-cell {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.asset-cell + .asset-cell {
  border-left: 1rpx solid #EAEFF6;
  padding-left: 28rpx;
}

.asset-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  height: 70rpx;
  flex: 0 0 70rpx;
  margin-right: 18rpx;
  border-radius: 20rpx;
}

.asset-icon.blue {
  color: #1F6BFF;
  background: linear-gradient(145deg, #E6F0FF, #D6E5FF);
}

.asset-icon.gold {
  color: #C9920F;
  background: linear-gradient(145deg, #FFF3D6, #FFE9B8);
}

.asset-icon .iconfont {
  font-size: 38rpx;
}

.asset-value {
  color: #0B1F3A;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
}

.asset-value.gold {
  color: #B8862B;
}

.asset-label {
  margin-top: 8rpx;
  color: #8A95A6;
  font-size: 22rpx;
}

/* Heading */
.heading {
  display: flex;
  align-items: center;
  margin: 34rpx 4rpx 20rpx;
  padding-left: 18rpx;
  color: #0B1F3A;
  font-size: 32rpx;
  font-weight: 900;
  border-left: 8rpx solid #2F6BEA;
}

/* Tier grid */
.tier-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 22rpx;
}

.tier-card {
  width: calc(50% - 11rpx);
  box-sizing: border-box;
  padding: 26rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 30rpx rgba(15, 35, 70, 0.06);
}

.tier-range {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 14rpx;
  color: #5A6B85;
  font-size: 22rpx;
  font-weight: 700;
  background: #EEF2F8;
}

.tier-integral {
  margin-top: 22rpx;
  color: #1E54D6;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
}

.tier-integral text {
  margin-left: 6rpx;
  color: #1E54D6;
  font-size: 24rpx;
  font-weight: 700;
}

.tier-voucher {
  margin-top: 14rpx;
  padding-bottom: 22rpx;
  border-bottom: 1rpx dashed #E2E8F1;
  color: #B8862B;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
}

.tier-voucher text {
  margin-left: 6rpx;
  color: #B8862B;
  font-size: 24rpx;
  font-weight: 700;
}

.tier-btn {
  margin-top: 22rpx;
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  border-radius: 18rpx;
  color: #1E54D6;
  font-size: 27rpx;
  font-weight: 800;
  background: #EAF1FF;
}

.tip {
  display: flex;
  align-items: center;
  margin: 30rpx 4rpx 0;
  color: #8A95A6;
  font-size: 23rpx;
}

.tip .iconfont {
  margin-right: 10rpx;
  color: #A9B4C4;
  font-size: 28rpx;
}

/* Modal */
.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: flex-end;
  background: rgba(11, 22, 45, 0.5);
}

.modal {
  width: 100%;
  padding: 34rpx 36rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  border-radius: 36rpx 36rpx 0 0;
  background: #F7FAFE;
}

.modal-head {
  display: flex;
  align-items: center;
}

.modal-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  flex: 0 0 78rpx;
  margin-right: 20rpx;
  border-radius: 22rpx;
  color: #1F6BFF;
  background: linear-gradient(145deg, #E6F0FF, #D6E5FF);
}

.modal-icon .iconfont {
  font-size: 42rpx;
}

.modal-head-text {
  flex: 1;
  min-width: 0;
}

.modal-title {
  color: #0B1F3A;
  font-size: 34rpx;
  font-weight: 900;
}

.modal-sub {
  margin-top: 8rpx;
  color: #8A95A6;
  font-size: 23rpx;
}

.modal-close {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  color: #97A2B2;
  background: #ECEFF4;
}

.modal-close .iconfont {
  font-size: 28rpx;
}

.field-label {
  margin: 28rpx 0 14rpx;
  color: #1A2236;
  font-size: 26rpx;
  font-weight: 700;
}

.type-row {
  display: flex;
  gap: 18rpx;
}

.type-chip {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 18rpx;
  color: #42526E;
  font-size: 27rpx;
  font-weight: 700;
  background: #fff;
  border: 1rpx solid #E2E8F1;
}

.type-chip.active {
  color: #1E54D6;
  background: #EAF1FF;
  border: 1rpx solid #1E54D6;
}

.field-input {
  height: 92rpx;
  padding: 0 26rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  color: #0B1F3A;
  background: #fff;
  border: 1rpx solid #E2E8F1;
  box-sizing: border-box;
}

.ph {
  color: #B6BECB;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
}

.modal-btn {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  border-radius: 46rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.modal-btn.cancel {
  color: #1E54D6;
  background: #fff;
  border: 1rpx solid #C9D8F2;
}

.modal-btn.submit {
  color: #fff;
  background: linear-gradient(135deg, #2F6BEA, #1E54D6);
  box-shadow: 0 12rpx 26rpx rgba(31, 84, 224, 0.34);
}

.modal-btn.submit.disabled {
  opacity: 0.6;
}

.modal-tip {
  margin-top: 22rpx;
  text-align: center;
  color: #A9B4C4;
  font-size: 22rpx;
}
