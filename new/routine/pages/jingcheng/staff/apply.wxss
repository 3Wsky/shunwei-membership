page {
  background: #F5F9FF;
}

.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 56rpx;
  box-sizing: border-box;
  color: #0B1F3A;
  background: linear-gradient(to bottom, #F7FBFF 0%, #EEF5FF 100%);
}

/* User Member Card Area */
.user-card-wrapper {
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 36rpx rgba(31, 107, 255, 0.12);
  margin-bottom: 34rpx;
}

.user-card-blue {
  position: relative;
  height: 220rpx;
  padding: 36rpx 32rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #2F7BFF 0%, #1F6BFF 100%);
  display: flex;
  align-items: center;
}

.profile-top {
  display: flex;
  align-items: center;
  width: 100%;
  z-index: 2;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  border: 4rpx solid rgba(255, 255, 255, 0.6);
}

.profile-info {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.profile-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 700;
}

.profile-meta {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 23rpx;
}

.profile-badge {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  color: #B8862B;
  font-size: 22rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FFF0CC 0%, #FFE099 100%);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.profile-badge .iconfont {
  margin-right: 6rpx;
  font-size: 24rpx;
}

.card-deco {
  position: absolute;
  right: -20rpx;
  bottom: -30rpx;
  color: rgba(255, 255, 255, 0.12);
  z-index: 1;
}

.card-deco .iconfont {
  font-size: 200rpx;
}

/* Current Asset Statistics */
.user-card-white {
  display: flex;
  align-items: center;
  height: 150rpx;
  background: #FFFFFF;
  padding: 0 32rpx;
}

.asset-cell {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.asset-icon-3d {
  font-size: 48rpx;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.asset-icon-3d.blue-icon {
  color: #1F6BFF;
  background: #EFF6FF;
}

.asset-icon-3d.gold-icon {
  color: #B8862B;
  background: #FFFDF9;
}

.asset-text {
  display: flex;
  flex-direction: column;
}

.asset-value {
  color: #B8862B;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.1;
}

.asset-label {
  margin-top: 6rpx;
  color: #8A95A6;
  font-size: 22rpx;
}

.asset-divider {
  width: 1rpx;
  height: 80rpx;
  background: #E6EEF8;
  margin: 0 24rpx;
}

/* Heading */
.heading {
  display: flex;
  align-items: center;
  margin: 40rpx 4rpx 24rpx;
  color: #0B1F3A;
  font-size: 32rpx;
  font-weight: 700;
}

.heading-bar {
  width: 8rpx;
  height: 34rpx;
  background: #1F6BFF;
  border-radius: 4rpx;
  margin-right: 18rpx;
}

/* Tier grid */
.tier-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.tier-card {
  position: relative;
  width: calc(50% - 10rpx);
  margin-bottom: 20rpx;
  height: 280rpx;
  box-sizing: border-box;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  border: 1rpx solid #E6EEF8;
  box-shadow: 0 12rpx 30rpx rgba(15, 35, 70, 0.04);
  transition: all 0.25s ease;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.tier-card.active {
  border: 3rpx solid #1F6BFF;
  background: linear-gradient(135deg, #FFFFFF 0%, #F5F9FF 100%);
  box-shadow: 0 12rpx 36rpx rgba(31, 107, 255, 0.1);
}

.tier-badge {
  align-self: flex-start;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  color: #8A95A6;
  font-size: 20rpx;
  font-weight: 700;
  background: #F0F4FA;
  line-height: 1.2;
  z-index: 2;
}

.tier-integral {
  margin-top: 18rpx;
  color: #1F6BFF;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1;
  z-index: 2;
}

.tier-integral text {
  margin-left: 6rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.tier-divider {
  margin-top: 14rpx;
  border-bottom: 1rpx dashed #E6EEF8;
  z-index: 2;
}

.tier-voucher {
  margin-top: 14rpx;
  color: #B8862B;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1;
  z-index: 2;
}

.tier-voucher text {
  margin-left: 6rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.tier-btn-select {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  color: #1F6BFF;
  font-size: 24rpx;
  font-weight: 700;
  background: #EFF6FF;
  z-index: 2;
  transition: all 0.2s ease;
}

.tier-card.active .tier-btn-select {
  background: #1F6BFF;
  color: #FFFFFF;
}

.check-icon-circle {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #1F6BFF;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
}

.check-icon-circle .iconfont {
  font-size: 20rpx;
}

.tier-watermark {
  position: absolute;
  right: -10rpx;
  top: 20rpx;
  color: rgba(31, 107, 255, 0.04);
  z-index: 1;
}

.tier-watermark .iconfont {
  font-size: 140rpx;
}

/* Bottom Tip */
.tip {
  display: flex;
  align-items: center;
  margin-top: 34rpx;
  padding: 22rpx 28rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid #E6EEF8;
  color: #8A95A6;
  font-size: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 35, 70, 0.02);
}

.tip .iconfont {
  margin-right: 14rpx;
  color: #1F6BFF;
  font-size: 28rpx;
  flex-shrink: 0;
}

/* Modal Popup */
.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: flex-end;
  background: rgba(11, 31, 58, 0.45);
  backdrop-filter: blur(8px);
}

.modal {
  width: 100%;
  padding: 36rpx 36rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  border-radius: 40rpx 40rpx 0 0;
  background: #FFFFFF;
  box-shadow: 0 -12rpx 48rpx rgba(11, 31, 58, 0.08);
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-head {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #EFF6FF 0%, #F8FBFF 100%);
  padding: 24rpx 28rpx;
  border-radius: 28rpx;
  margin-bottom: 28rpx;
  position: relative;
}

.modal-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  flex: 0 0 78rpx;
  margin-right: 20rpx;
  border-radius: 22rpx;
  color: #1F6BFF;
  background: #FFFFFF;
  box-shadow: 0 6rpx 16rpx rgba(31, 107, 255, 0.08);
}

.modal-icon .iconfont {
  font-size: 42rpx;
}

.modal-head-text {
  flex: 1;
  min-width: 0;
}

.modal-title {
  color: #0B1F3A;
  font-size: 34rpx;
  font-weight: 700;
}

.modal-sub {
  margin-top: 6rpx;
  color: #8A95A6;
  font-size: 23rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.modal-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  color: #2F4A6D;
  background: #EAF2FF;
  transition: all 0.2s ease;
}

.modal-close .iconfont {
  font-size: 24rpx;
}

/* Scroll Area inside Modal */
.modal-scroll {
  max-height: 55vh;
  margin-bottom: 24rpx;
  padding-right: 4rpx;
}

/* Product Section */
.product-section {
  border: 1rpx solid #E6EEF8;
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 28rpx;
  background: #F8FBFF;
}

.product-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx dashed #E6EEF8;
}

.product-section-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1F6BFF;
}

.product-section-remove {
  display: flex;
  align-items: center;
  color: #E34D59;
  font-size: 24rpx;
  font-weight: 700;
}

.product-section-remove .iconfont {
  font-size: 24rpx;
  margin-right: 6rpx;
}

/* Add Product Button */
.add-product-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border: 2rpx dashed #1F6BFF;
  border-radius: 24rpx;
  color: #1F6BFF;
  font-size: 28rpx;
  font-weight: 700;
  background: #EFF6FF;
  margin-bottom: 20rpx;
  transition: all 0.2s ease;
}

.add-product-btn .iconfont {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.field-label {
  margin: 20rpx 0 12rpx;
  color: #0B1F3A;
  font-size: 26rpx;
  font-weight: 700;
}

.type-row {
  display: flex;
  margin-bottom: 20rpx;
}

.type-chip {
  flex: 1;
  margin-right: 14rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 20rpx;
  color: #42526E;
  font-size: 26rpx;
  font-weight: 700;
  background: #FFFFFF;
  border: 1rpx solid #E6EEF8;
  transition: all 0.2s ease;
}

.type-chip:last-child {
  margin-right: 0;
}

.type-chip.active {
  color: #1F6BFF;
  background: #FFFFFF;
  border: 2rpx solid #1F6BFF;
  box-shadow: 0 4rpx 12rpx rgba(31, 107, 255, 0.08);
}

/* Input Card Style */
.input-card {
  position: relative;
  display: flex;
  align-items: center;
  height: 132rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 28rpx rgba(15, 35, 70, 0.03);
  border: 1rpx solid #E6EEF8;
  box-sizing: border-box;
}

.input-card-left-line {
  width: 6rpx;
  height: 32rpx;
  background: #1F6BFF;
  border-radius: 4rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.input-card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.input-card-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #0B1F3A;
  line-height: 1.2;
  margin-bottom: 4rpx;
}

.field-input-new {
  height: 48rpx;
  font-size: 28rpx;
  color: #0B1F3A;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  width: 100%;
}

.field-input-new.mono {
  font-family: 'Courier New', Consolas, monospace;
  letter-spacing: 1rpx;
}

.input-card-icon {
  font-size: 32rpx;
  color: #1F6BFF;
  background: #EFF6FF;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.ph {
  color: #B4BDCC;
}

/* Scan Row */
.scan-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(31, 107, 255, 0.06), rgba(31, 107, 255, 0.01));
  border: 1rpx solid rgba(31, 107, 255, 0.15);
}

.scan-tip {
  font-size: 24rpx;
  color: #1F6BFF;
  font-weight: 700;
}

.scan-btn-sm {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #4D9BFF, #1F6BFF);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 16rpx rgba(31, 107, 255, 0.2);
  transition: all 0.2s ease;
}

.scan-btn-sm .iconfont {
  margin-right: 8rpx;
  font-size: 26rpx;
}

.scan-btn-sm.disabled {
  opacity: 0.5;
}

/* Modal Actions */
.modal-actions {
  display: flex;
  margin-top: 36rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  transition: all 0.2s ease;
}

.modal-btn.cancel {
  margin-right: 20rpx;
  color: #1F6BFF;
  background: #FFFFFF;
  border: 1rpx solid #1F6BFF;
}

.modal-btn.submit {
  color: #FFFFFF;
  background: linear-gradient(135deg, #4D9BFF, #1F6BFF);
  box-shadow: 0 10rpx 24rpx rgba(31, 107, 255, 0.28);
}

.modal-btn.submit.disabled {
  background: #D8E2F0 !important;
  color: #FFFFFF !important;
  box-shadow: none !important;
  opacity: 1;
}

.modal-tip {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8A95A6;
  font-size: 24rpx;
}

.modal-tip .iconfont {
  margin-right: 10rpx;
  color: #1F6BFF;
  font-size: 26rpx;
}
