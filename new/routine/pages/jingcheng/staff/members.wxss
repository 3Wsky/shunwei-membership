page {
  background: linear-gradient(180deg, #F7FBFF 0%, #EEF5FF 100%);
}

.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 56rpx;
  box-sizing: border-box;
  color: #0B1F3A;
  background:
    radial-gradient(circle at 82% 6%, rgba(77, 155, 255, 0.14), transparent 260rpx),
    linear-gradient(180deg, #F7FBFF 0%, #EEF5FF 100%);
}

.manager-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
  padding: 30rpx 32rpx;
  border-radius: 26rpx;
  color: #fff;
  background: linear-gradient(135deg, #1E5BB8, #14457F);
  box-shadow: 0 14rpx 34rpx rgba(20, 69, 127, 0.28);
}

.manager-entry text {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
}

.manager-entry label {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 22rpx;
}

.badge {
  flex: 0 0 auto;
  color: #FFE6A6;
  font-size: 24rpx;
  font-weight: 700;
}

.search {
  display: flex;
  align-items: center;
  padding: 14rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.97);
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
}

.search input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #F1F5FB;
  border-radius: 16rpx;
  font-size: 26rpx;
}

.search button {
  margin: 0 0 0 14rpx;
  padding: 0 34rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 27rpx;
  font-weight: 700;
  color: #fff;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #2F6BEA, #1E54D6);
}

.search button::after {
  border: none;
}

.summary {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 28rpx 8rpx 16rpx;
  color: #42526E;
  font-size: 26rpx;
  font-weight: 700;
}

.uid-hint {
  font-size: 22rpx;
  color: #A9B4C4;
  font-weight: 400;
}

.warn-hint {
  font-size: 22rpx;
  color: #C45C26;
  font-weight: 400;
  line-height: 1.5;
}

.member {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.97);
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 10rpx 30rpx rgba(15, 35, 70, 0.05);
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #eef2f8;
}

.info {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #1E54D6;
  font-size: 30rpx;
  font-weight: 800;
}

.tier {
  margin-left: 10rpx;
  font-size: 20rpx;
  font-weight: 400;
  color: #9b7715;
  background: #fbf6e8;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.meta {
  margin-top: 10rpx;
  color: #8A95A6;
  font-size: 23rpx;
}

.balances {
  margin-top: 10rpx;
  color: #B8862B;
  font-size: 24rpx;
}

.status {
  flex: 0 0 auto;
  margin-left: 14rpx;
  color: #C99A2E;
  font-size: 34rpx;
  font-weight: 700;
}

.empty,
.loading {
  text-align: center;
  padding: 70rpx 24rpx;
  color: #8A95A6;
}

.empty-title {
  margin-bottom: 16rpx;
  font-size: 30rpx;
  color: #42526E;
  font-weight: 700;
}

.empty-desc {
  margin-top: 12rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8A95A6;
  text-align: left;
  background: rgba(255, 255, 255, 0.97);
  border: 1rpx solid rgba(230, 238, 248, 0.9);
}

.login-btn {
  margin-top: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #2F6BEA, #1E54D6);
}

.login-btn::after {
  border: none;
}

.strong {
  color: #C45C26;
  font-weight: 600;
}
