.page{min-height:100vh;background:#f5f3f0;padding:24rpx;box-sizing:border-box}.manager-entry{display:flex;justify-content:space-between;align-items:center;background:#1a1f36;color:#fff;padding:25rpx;border-radius:18rpx;margin-bottom:18rpx}.manager-entry text{display:block;font-size:29rpx;font-weight:600}.manager-entry label{display:block;color:#b9bdce;font-size:22rpx;margin-top:7rpx}.badge{color:#e0c66f;font-size:24rpx}.search{display:flex;background:#fff;padding:16rpx;border-radius:18rpx}.search input{flex:1;height:64rpx;padding:0 18rpx;background:#f7f6f3;border-radius:12rpx}.search button{margin:0 0 0 12rpx;height:64rpx;line-height:64rpx;font-size:26rpx;background:#1a1f36;color:#d8bc61}.summary{padding:26rpx 8rpx 16rpx;color:#777;font-size:25rpx;display:flex;flex-direction:column;gap:8rpx}.uid-hint{font-size:22rpx;color:#aaa}.warn-hint{font-size:22rpx;color:#c45c26;line-height:1.5}.member{display:flex;align-items:center;background:#fff;margin-bottom:16rpx;padding:24rpx;border-radius:18rpx}.avatar{width:86rpx;height:86rpx;border-radius:50%;background:#eee}.info{flex:1;min-width:0;margin-left:20rpx}.name{font-weight:600;color:#1a1f36;font-size:29rpx}.tier{font-size:20rpx;font-weight:400;color:#9b7715;background:#fbf6e8;padding:4rpx 9rpx;border-radius:8rpx}.meta{margin-top:8rpx;color:#999;font-size:23rpx}.balances{margin-top:10rpx;color:#9b7715;font-size:24rpx}.status{color:#b48b16;font-size:24rpx}.empty,.loading{text-align:center;padding:60rpx 24rpx;color:#999}.empty-title{font-size:30rpx;color:#666;margin-bottom:16rpx}.empty-desc,.empty-steps{font-size:24rpx;line-height:1.6;color:#999;text-align:left;background:#fff;padding:24rpx;border-radius:16rpx;margin-top:12rpx}.login-btn{margin-top:24rpx;background:#1a1f36;color:#d8bc61;font-size:28rpx}.login-btn.ghost{background:#fff;color:#1a1f36;border:1rpx solid #ddd}.strong{color:#c45c26;font-weight:600}
