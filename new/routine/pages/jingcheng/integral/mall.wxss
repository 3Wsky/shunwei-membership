page {
  background: #F5F3F0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 56rpx;
  box-sizing: border-box;
  color: #1A1A1A;
  background: #F5F3F0;
}

/* Balance card */
.balance-card {
  position: relative;
  overflow: hidden;
  padding: 36rpx;
  border-radius: 24rpx;
  color: #fff;
  background: linear-gradient(135deg, #1A1F36 0%, #2D3561 100%);
  box-shadow: 0 12rpx 36rpx rgba(26, 31, 54, 0.16);
}

.bc-bg {
  position: absolute;
  top: 10rpx;
  right: 20rpx;
  opacity: 0.16;
}

.bc-bg .iconfont {
  font-size: 150rpx;
  color: #fff;
}

.bc-label {
  position: relative;
  z-index: 2;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.bc-value {
  position: relative;
  z-index: 2;
  margin: 12rpx 0 8rpx;
  font-size: 66rpx;
  font-weight: 900;
  line-height: 1;
  color: #D4AF37;
}

.bc-sub {
  position: relative;
  z-index: 2;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.78);
}

/* Section title */
.section-title {
  display: flex;
  align-items: center;
  margin: 34rpx 4rpx 18rpx;
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 800;
}

.section-badge {
  margin-left: 10rpx;
  padding: 2rpx 12rpx;
  border-radius: 14rpx;
  color: #C9A227;
  font-size: 20rpx;
  font-weight: 700;
  background: #FFF9E6;
}

/* Grid */
.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 22rpx;
}

.card {
  width: calc(50% - 11rpx);
  box-sizing: border-box;
  border-radius: 24rpx;
  overflow: hidden;
  background: #FFFFFF;
  border: 1rpx solid rgba(201, 162, 39, 0.08);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.cover-wrap {
  position: relative;
  width: 100%;
  height: 330rpx;
  background: #F5F3F0;
}

.cover {
  width: 100%;
  height: 330rpx;
}

.cover.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 70rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #1A1F36, #C9A227);
}

.cover-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12rpx 0;
  text-align: center;
  color: #fff;
  font-size: 22rpx;
  background: rgba(11, 22, 45, 0.55);
}

.card-body {
  padding: 20rpx 22rpx 22rpx;
}

.name {
  height: 72rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  color: #1A1A1A;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.35;
}

.card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
}

.price {
  color: #C9A227;
  font-size: 22rpx;
  font-weight: 700;
}

.price-num {
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
}

.go {
  flex: 0 0 auto;
  padding: 8rpx 18rpx;
  border-radius: 22rpx;
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #E6B84E, #C9A227);
  box-shadow: 0 4rpx 12rpx rgba(201, 162, 39, 0.2);
}

/* Empty / loading */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 110rpx 0;
  color: #8C8C8C;
  font-size: 26rpx;
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 18rpx;
  border-radius: 36rpx;
  color: #D4AF37;
  background: linear-gradient(145deg, #FFF9E6, #FFF0CC);
}

.empty-icon .iconfont {
  font-size: 60rpx;
}

.loading {
  padding: 40rpx 0;
  text-align: center;
  color: #8C8C8C;
  font-size: 24rpx;
}
