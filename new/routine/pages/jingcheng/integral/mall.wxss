page {
  background: linear-gradient(180deg, #F7FBFF 0%, #EEF5FF 100%);
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 56rpx;
  box-sizing: border-box;
  color: #0B1F3A;
  background:
    radial-gradient(circle at 82% 6%, rgba(77, 155, 255, 0.14), transparent 260rpx),
    linear-gradient(180deg, #F7FBFF 0%, #EEF5FF 100%);
}

/* Balance card */
.balance-card {
  position: relative;
  overflow: hidden;
  padding: 36rpx;
  border-radius: 30rpx;
  color: #fff;
  background: linear-gradient(135deg, #2F6BEA, #1E54D6);
  box-shadow: 0 16rpx 40rpx rgba(31, 84, 224, 0.28);
}

.bc-bg {
  position: absolute;
  top: 10rpx;
  right: 20rpx;
  opacity: 0.16;
}

.bc-bg .iconfont {
  font-size: 150rpx;
  color: #fff;
}

.bc-label {
  position: relative;
  z-index: 2;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.bc-value {
  position: relative;
  z-index: 2;
  margin: 12rpx 0 8rpx;
  font-size: 66rpx;
  font-weight: 900;
  line-height: 1;
}

.bc-sub {
  position: relative;
  z-index: 2;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.78);
}

/* Section title */
.section-title {
  display: flex;
  align-items: center;
  margin: 34rpx 4rpx 18rpx;
  color: #0B1F3A;
  font-size: 32rpx;
  font-weight: 800;
}

.section-badge {
  margin-left: 10rpx;
  padding: 2rpx 12rpx;
  border-radius: 14rpx;
  color: #1F6BFF;
  font-size: 20rpx;
  font-weight: 700;
  background: #EEF5FF;
}

/* Grid */
.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 22rpx;
}

.card {
  width: calc(50% - 11rpx);
  box-sizing: border-box;
  border-radius: 26rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 30rpx rgba(15, 35, 70, 0.06);
}

.cover-wrap {
  position: relative;
  width: 100%;
  height: 330rpx;
  background: #EEF3FA;
}

.cover {
  width: 100%;
  height: 330rpx;
}

.cover.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 70rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #2F6BEA, #B8862B);
}

.cover-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12rpx 0;
  text-align: center;
  color: #fff;
  font-size: 22rpx;
  background: rgba(11, 22, 45, 0.55);
}

.card-body {
  padding: 20rpx 22rpx 22rpx;
}

.name {
  height: 72rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  color: #1A2236;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.35;
}

.card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
}

.price {
  color: #B8862B;
  font-size: 22rpx;
  font-weight: 700;
}

.price-num {
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
}

.go {
  flex: 0 0 auto;
  padding: 8rpx 18rpx;
  border-radius: 22rpx;
  color: #1E54D6;
  font-size: 22rpx;
  font-weight: 800;
  background: #EAF1FF;
}

/* Empty / loading */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 110rpx 0;
  color: #9AA5B8;
  font-size: 26rpx;
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 18rpx;
  border-radius: 36rpx;
  color: #9CC0FF;
  background: linear-gradient(145deg, #EAF2FF, #FFFFFF);
}

.empty-icon .iconfont {
  font-size: 60rpx;
}

.loading {
  padding: 40rpx 0;
  text-align: center;
  color: #9AA5B8;
  font-size: 24rpx;
}
