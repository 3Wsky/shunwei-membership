page {
  background: #F5F3F0;
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  box-sizing: border-box;
  color: #1A1A1A;
  background: #F5F3F0;
}

/* Hero image */
.hero {
  width: 100%;
  height: 600rpx;
  background: #F5F3F0;
}

.hero-img {
  width: 100%;
  height: 600rpx;
}

.hero.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 120rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #1A1F36, #C9A227);
}

/* Info card */
.info-card {
  position: relative;
  margin: -40rpx 28rpx 0;
  padding: 30rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(201, 162, 39, 0.08);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.price {
  color: #C9A227;
  font-size: 26rpx;
  font-weight: 700;
}

.price-num {
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1;
}

.stock {
  color: #8C8C8C;
  font-size: 23rpx;
}

.title {
  margin-top: 18rpx;
  color: #1A1A1A;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.35;
}

.subtitle {
  margin-top: 10rpx;
  color: #8C8C8C;
  font-size: 24rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 20rpx;
}

.tag {
  padding: 6rpx 18rpx;
  border-radius: 12rpx;
  font-size: 21rpx;
  font-weight: 700;
  margin-right: 14rpx;
  margin-bottom: 14rpx;
}

.tag.gold {
  color: #8C7355;
  background: #FBF8F5;
}

.tag.blue {
  color: #C9A227;
  background: #FFF9E6;
}

.tag.plain {
  color: #8C8C8C;
  background: #F5F3F0;
}

/* Rule card */
.rule-card {
  margin: 22rpx 28rpx 0;
  padding: 10rpx 30rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(201, 162, 39, 0.08);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.rule-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #F0F4FA;
}

.rule-row:last-child {
  border-bottom: 0;
}

.rk {
  display: flex;
  align-items: center;
  color: #8C8C8C;
  font-size: 25rpx;
}

.rk .iconfont {
  margin-right: 12rpx;
  color: #C9A227;
  font-size: 30rpx;
}

.rv {
  max-width: 56%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #1A1A1A;
  font-size: 26rpx;
  font-weight: 700;
}

.rv.gold {
  color: #C9A227;
  font-size: 30rpx;
  font-weight: 900;
}

.rv.muted {
  color: #8C8C8C;
  font-weight: 400;
}

/* Description */
.section-title {
  margin: 34rpx 32rpx 16rpx;
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 800;
}

.desc-card {
  margin: 0 28rpx;
  padding: 30rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(201, 162, 39, 0.08);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
  font-size: 27rpx;
  line-height: 1.7;
  color: #4A4A4A;
}

.desc-card rich-text image,
.desc-card rich-text img {
  max-width: 100%;
}

.desc-empty {
  text-align: center;
  padding: 30rpx 10rpx;
}

.de-title {
  color: #1A1A1A;
  font-size: 28rpx;
  font-weight: 800;
}

.de-sub {
  margin-top: 12rpx;
  color: #8C8C8C;
  font-size: 24rpx;
  line-height: 1.6;
}

/* Bottom bar */
.bottom-spacer {
  height: 140rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-top: 1rpx solid #EBF0F7;
  box-shadow: 0 -6rpx 24rpx rgba(0, 0, 0, 0.04);
}

.bb-left {
  display: flex;
  flex-direction: column;
  margin-right: 24rpx;
}

.bb-num {
  color: #C9A227;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.bb-label {
  margin-top: 6rpx;
  color: #8C8C8C;
  font-size: 20rpx;
}

.bb-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #E6B84E, #C9A227);
  box-shadow: 0 6rpx 16rpx rgba(201, 162, 39, 0.2);
}

.bb-btn.disabled {
  color: #fff;
  background: #BCC6D6;
  box-shadow: none;
}
