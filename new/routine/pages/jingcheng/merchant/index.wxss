page {
  background: linear-gradient(180deg, #F7FBFF 0%, #EEF5FF 100%);
}

.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 56rpx;
  box-sizing: border-box;
  color: #0B1F3A;
  background:
    radial-gradient(circle at 82% 6%, rgba(77, 155, 255, 0.14), transparent 260rpx),
    linear-gradient(180deg, #F7FBFF 0%, #EEF5FF 100%);
}

/* Hero */
.hero {
  position: relative;
  min-height: 252rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(15, 35, 90, 0.18);
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero-body {
  position: relative;
  z-index: 2;
  padding: 36rpx;
}

.hero-kicker {
  color: #F4D58D;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.hero-title {
  margin-top: 10rpx;
  color: #fff;
  font-size: 44rpx;
  font-weight: 900;
}

.hero-role {
  display: inline-block;
  margin-top: 14rpx;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  color: #F4D58D;
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(244, 213, 141, 0.5);
}

.hero-desc {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 23rpx;
}

/* Verify entry */
.verify-entry {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
  padding: 26rpx 28rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.97);
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
}

.ve-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  flex: 0 0 84rpx;
  margin-right: 22rpx;
  border-radius: 24rpx;
  color: #1F3A6B;
  background: linear-gradient(145deg, #EAF1FF, #DCE7FF);
}

.ve-icon .iconfont {
  font-size: 46rpx;
}

.ve-main {
  flex: 1;
  min-width: 0;
}

.ve-title {
  color: #0B1F3A;
  font-size: 32rpx;
  font-weight: 800;
}

.ve-sub {
  margin-top: 8rpx;
  color: #8A95A6;
  font-size: 23rpx;
}

.ve-action {
  flex: 0 0 auto;
  color: #B8862B;
  font-size: 26rpx;
  font-weight: 800;
}

/* Section title */
.section-title {
  margin: 34rpx 4rpx 18rpx;
  color: #0B1F3A;
  font-size: 32rpx;
  font-weight: 800;
}

/* Overview */
.overview-card {
  display: flex;
  padding: 30rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.97);
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
  box-sizing: border-box;
}

.ov-main {
  flex: 1;
  min-width: 0;
}

.ov-label,
.ov-desc {
  color: #8A95A6;
  font-size: 23rpx;
}

.ov-value {
  margin: 14rpx 0 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #B8862B;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1;
}

.ov-grid {
  display: flex;
  width: 280rpx;
  margin-left: 22rpx;
  border-left: 1rpx solid #E6EEF8;
}

.ov-grid view {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 0;
}

.ov-grid text {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #0B1F3A;
  font-size: 30rpx;
  font-weight: 800;
}

.ov-grid label {
  margin-top: 8rpx;
  color: #8A95A6;
  font-size: 21rpx;
}

/* Management entries */
.entry-grid {
  display: flex;
  gap: 22rpx;
}

.entry-card {
  flex: 1;
  min-width: 0;
  padding: 28rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.97);
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
  box-sizing: border-box;
}

.entry-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
}

.entry-icon .iconfont {
  font-size: 42rpx;
}

.entry-icon.blue {
  color: #1F6BFF;
  background: linear-gradient(145deg, #E6F0FF, #D6E5FF);
}

.entry-icon.gold {
  color: #C9920F;
  background: linear-gradient(145deg, #FFF3D6, #FFE9B8);
}

.entry-icon.navy {
  color: #1F3A6B;
  background: linear-gradient(145deg, #E4ECFB, #D3DEF5);
}

.entry-name {
  margin-top: 18rpx;
  color: #0B1F3A;
  font-size: 30rpx;
  font-weight: 800;
}

.entry-sub {
  margin-top: 8rpx;
  color: #8A95A6;
  font-size: 22rpx;
}

.entry-row {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
  padding: 26rpx 28rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.97);
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
}

.entry-row .entry-icon {
  flex: 0 0 76rpx;
  margin-right: 22rpx;
}

.entry-row-main {
  flex: 1;
  min-width: 0;
}

.entry-row .entry-name {
  margin-top: 0;
}

.entry-arrow {
  flex: 0 0 auto;
  color: #C0C9D6;
  font-size: 40rpx;
}

/* Total card */
.total-card {
  display: flex;
  margin-top: 24rpx;
  padding: 30rpx 20rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #1B2A5E, #24337A);
  box-shadow: 0 16rpx 36rpx rgba(20, 35, 90, 0.22);
}

.total-card view {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.total-card view + view {
  border-left: 1rpx solid rgba(255, 255, 255, 0.14);
}

.total-card text {
  color: #F4D58D;
  font-size: 36rpx;
  font-weight: 900;
}

.total-card label {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 21rpx;
}
