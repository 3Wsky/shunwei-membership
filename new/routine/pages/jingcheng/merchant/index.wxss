.page{min-height:100vh;background:#f5f3f0;padding:24rpx 24rpx 60rpx;box-sizing:border-box}.merchant-head{display:flex;justify-content:space-between;align-items:center;background:linear-gradient(135deg,#1a1f36,#343b62);padding:30rpx;border-radius:22rpx;color:#fff}.merchant-head label{display:block;color:#aeb2c5;font-size:22rpx}.merchant-head text{display:block;font-size:34rpx;font-weight:600;margin-top:8rpx}.role{color:#e3ca75;border:1rpx solid rgba(227,202,117,.5);padding:8rpx 18rpx;border-radius:30rpx;font-size:23rpx}.verify-card{display:flex;justify-content:space-between;align-items:center;background:#fff;margin-top:18rpx;padding:28rpx;border-radius:18rpx;border-left:6rpx solid #c9a227}.verify-card text{display:block;font-size:31rpx;font-weight:600;color:#1a1f36}.verify-card label{display:block;font-size:22rpx;color:#999;margin-top:8rpx}.scan{font-size:25rpx;color:#a37e16}.title{font-size:29rpx;font-weight:600;color:#252a3d;margin:32rpx 6rpx 16rpx}.stats{display:grid;grid-template-columns:1fr 1fr;background:#fff;border-radius:18rpx;padding:8rpx}.stats view{display:flex;flex-direction:column;align-items:center;padding:24rpx}.stats view:nth-child(odd){border-right:1rpx solid #eee}.stats view:nth-child(-n+2){border-bottom:1rpx solid #eee}.stats text{font-size:35rpx;font-weight:700;color:#b48b16}.stats label{font-size:22rpx;color:#999;margin-top:8rpx}.withdraw-card{background:#fff;border-radius:20rpx;padding:28rpx;margin-top:22rpx}.withdraw-head{display:flex}.withdraw-head>view{width:50%}.withdraw-head label{display:block;font-size:22rpx;color:#999}.withdraw-head text{display:block;font-size:45rpx;color:#b48b16;font-weight:700;margin-top:8rpx}.withdraw-head .small{font-size:32rpx;color:#777}.arrival{background:#fbf6e8;color:#8c6b12;font-size:23rpx;padding:17rpx;margin:22rpx 0;border-radius:12rpx}.all{background:#1a1f36;color:#e1c76e;font-size:27rpx}.custom{display:flex;margin-top:15rpx;gap:12rpx}.custom input{flex:1;height:68rpx;background:#f7f6f3;border-radius:12rpx;padding:0 18rpx;font-size:25rpx}.custom button{height:68rpx;line-height:68rpx;background:#c9a227;color:#fff;font-size:24rpx}.withdraw-row{display:flex;justify-content:space-between;align-items:center;background:#fff;padding:23rpx;border-radius:15rpx;margin-bottom:12rpx}.withdraw-row text{display:block;font-size:30rpx;font-weight:600;color:#333}.withdraw-row label{display:block;font-size:21rpx;color:#999;margin-top:6rpx}.pending{color:#b48b16;font-size:23rpx}.settled{color:#2d9b63;font-size:23rpx}.empty{text-align:center;background:#fff;padding:45rpx;color:#aaa;border-radius:15rpx}
