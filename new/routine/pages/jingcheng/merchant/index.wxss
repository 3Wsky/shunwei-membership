page {
  background: linear-gradient(180deg, #F7FBFF 0%, #EEF5FF 100%);
}

.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 56rpx;
  box-sizing: border-box;
  color: #1A1A1A;
  background:
    radial-gradient(circle at 82% 6%, rgba(77, 155, 255, 0.12), transparent 260rpx),
    linear-gradient(180deg, #F7FBFF 0%, #EEF5FF 100%);
}

/* Hero */
.hero {
  position: relative;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #1A1F36 0%, #232A4A 52%, #2D3561 100%);
  box-shadow: 0 16rpx 40rpx rgba(26, 31, 54, 0.28);
}

/* Orbit rings (right side) */
.hero-orbit {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(122, 162, 247, 0.16);
  z-index: 1;
  pointer-events: none;
}

.hero-orbit-a {
  right: -90rpx;
  top: 40rpx;
  width: 300rpx;
  height: 300rpx;
}

.hero-orbit-b {
  right: -30rpx;
  top: 120rpx;
  width: 200rpx;
  height: 200rpx;
  border-color: rgba(122, 162, 247, 0.1);
}

.hero-spark {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(244, 213, 141, 0.9);
  box-shadow: 0 0 12rpx rgba(244, 213, 141, 0.6);
  z-index: 1;
}

.hero-spark-1 { right: 120rpx; top: 36rpx; }
.hero-spark-2 { right: 56rpx; top: 96rpx; width: 6rpx; height: 6rpx; }
.hero-spark-3 { right: 200rpx; top: 150rpx; width: 5rpx; height: 5rpx; opacity: 0.7; }

/* 3D-ish art cluster (CSS approximation of storefront + shield + crown) */
.hero-art {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 200rpx;
  height: 200rpx;
  z-index: 1;
  pointer-events: none;
}

.art-shop {
  position: absolute;
  right: 16rpx;
  top: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 150rpx;
  height: 150rpx;
  border-radius: 36rpx;
  color: #DCE6FF;
  background: linear-gradient(150deg, #3B4470, #2A3157);
  box-shadow: inset 0 2rpx 10rpx rgba(255,255,255,0.12), 0 12rpx 26rpx rgba(0,0,0,0.3);
}

.art-shop .iconfont {
  font-size: 96rpx;
}

.art-shield {
  position: absolute;
  right: 4rpx;
  bottom: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  color: #fff;
  background: linear-gradient(135deg, #4D9BFF, #1F6BFF);
  box-shadow: 0 8rpx 18rpx rgba(31, 107, 255, 0.45);
}

.art-shield .iconfont {
  font-size: 38rpx;
}

.art-crown {
  position: absolute;
  right: 92rpx;
  top: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  color: #2A2207;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #F8DC8E, #E6B84E);
  box-shadow: 0 8rpx 18rpx rgba(201, 162, 39, 0.4);
  transform: rotate(-12deg);
}

.art-crown .iconfont {
  font-size: 32rpx;
}

.hero-body {
  position: relative;
  z-index: 2;
  padding: 40rpx;
  padding-right: 220rpx;
}

.hero-kicker {
  color: #F4D58D;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.hero-title {
  margin-top: 10rpx;
  color: #fff;
  font-size: 44rpx;
  font-weight: 900;
}

.hero-role {
  display: inline-block;
  margin-top: 14rpx;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  color: #F4D58D;
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(244, 213, 141, 0.5);
}

.hero-desc {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 23rpx;
}

/* Verify entry */
.verify-entry {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
  padding: 26rpx 28rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
}

.ve-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  flex: 0 0 84rpx;
  margin-right: 22rpx;
  border-radius: 50%;
  color: #F4D58D;
  background: linear-gradient(135deg, #1A1F36, #2D3561);
  box-shadow: 0 6rpx 16rpx rgba(26, 31, 54, 0.22);
}

.ve-icon .iconfont {
  font-size: 46rpx;
}

.ve-main {
  flex: 1;
  min-width: 0;
}

.ve-title {
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 800;
}

.ve-sub {
  margin-top: 8rpx;
  color: #8C8C8C;
  font-size: 23rpx;
}

.ve-action {
  flex: 0 0 auto;
  color: #C9A227;
  font-size: 26rpx;
  font-weight: 800;
}

/* Section title */
.section-title {
  margin: 34rpx 4rpx 18rpx;
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 800;
}

/* Overview */
.overview-card {
  display: flex;
  padding: 30rpx 28rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
  box-sizing: border-box;
}

.ov-main {
  flex: 1;
  min-width: 0;
}

.ov-label,
.ov-desc {
  color: #8C8C8C;
  font-size: 23rpx;
}

.ov-value {
  margin: 14rpx 0 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #C9A227;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1;
}

.ov-grid {
  display: flex;
  width: 280rpx;
  margin-left: 22rpx;
  border-left: 1rpx solid #E5E5E5;
}

.ov-grid view {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 0;
}

.ov-grid text {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #1A1A1A;
  font-size: 30rpx;
  font-weight: 800;
}

.ov-grid label {
  margin-top: 8rpx;
  color: #8C8C8C;
  font-size: 21rpx;
}

/* Management entries */
.entry-grid {
  display: flex;
}

.entry-card {
  flex: 1;
  min-width: 0;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
  box-sizing: border-box;
}

.entry-grid .entry-card + .entry-card {
  margin-left: 22rpx;
}

.entry-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
}

.entry-icon .iconfont {
  font-size: 42rpx;
}

.entry-icon.blue {
  color: #1F6BFF;
  background: linear-gradient(145deg, #EEF5FF, #FFFFFF);
}

.entry-icon.gold {
  color: #C9A227;
  background: linear-gradient(145deg, #FFF9E6, #FFF0CC);
}

.entry-icon.navy {
  color: #F4D58D;
  background: linear-gradient(135deg, #1A1F36, #2D3561);
}

.entry-name {
  margin-top: 18rpx;
  color: #1A1A1A;
  font-size: 30rpx;
  font-weight: 800;
}

.entry-sub {
  margin-top: 8rpx;
  color: #8C8C8C;
  font-size: 22rpx;
}

.entry-row {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
  padding: 26rpx 28rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
}

.entry-row .entry-icon {
  flex: 0 0 76rpx;
  margin-right: 22rpx;
}

.entry-row-main {
  flex: 1;
  min-width: 0;
}

.entry-row .entry-name {
  margin-top: 0;
}

.entry-arrow {
  flex: 0 0 auto;
  color: #C0C9D6;
  font-size: 40rpx;
}

/* Total card */
.total-card {
  display: flex;
  margin-top: 24rpx;
  padding: 30rpx 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #1A1F36 0%, #2D3561 100%);
  box-shadow: 0 12rpx 36rpx rgba(26, 31, 54, 0.16);
}

.total-card view {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.total-card view + view {
  border-left: 1rpx solid rgba(255, 255, 255, 0.14);
}

.total-card text {
  color: #D4AF37;
  font-size: 36rpx;
  font-weight: 900;
}

.total-card label {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.75);
  font-size: 21rpx;
}
