page {
  background: #F5F3F0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 56rpx;
  box-sizing: border-box;
  color: #1A1A1A;
  background: #F5F3F0;
}

/* Hero */
.hero {
  position: relative;
  min-height: 252rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 36rpx rgba(26, 31, 54, 0.16);
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero-body {
  position: relative;
  z-index: 2;
  padding: 36rpx;
}

.hero-kicker {
  color: #F4D58D;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.hero-title {
  margin-top: 10rpx;
  color: #fff;
  font-size: 44rpx;
  font-weight: 900;
}

.hero-role {
  display: inline-block;
  margin-top: 14rpx;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  color: #F4D58D;
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(244, 213, 141, 0.5);
}

.hero-desc {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 23rpx;
}

/* Verify entry */
.verify-entry {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
  padding: 26rpx 28rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(201, 162, 39, 0.08);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.ve-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  flex: 0 0 84rpx;
  margin-right: 22rpx;
  border-radius: 20rpx;
  color: #C9A227;
  background: linear-gradient(145deg, #FFF9E6, #FFF0CC);
}

.ve-icon .iconfont {
  font-size: 46rpx;
}

.ve-main {
  flex: 1;
  min-width: 0;
}

.ve-title {
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 800;
}

.ve-sub {
  margin-top: 8rpx;
  color: #8C8C8C;
  font-size: 23rpx;
}

.ve-action {
  flex: 0 0 auto;
  color: #C9A227;
  font-size: 26rpx;
  font-weight: 800;
}

/* Section title */
.section-title {
  margin: 34rpx 4rpx 18rpx;
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 800;
}

/* Overview */
.overview-card {
  display: flex;
  padding: 30rpx 28rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(201, 162, 39, 0.08);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
  box-sizing: border-box;
}

.ov-main {
  flex: 1;
  min-width: 0;
}

.ov-label,
.ov-desc {
  color: #8C8C8C;
  font-size: 23rpx;
}

.ov-value {
  margin: 14rpx 0 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #C9A227;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1;
}

.ov-grid {
  display: flex;
  width: 280rpx;
  margin-left: 22rpx;
  border-left: 1rpx solid #E5E5E5;
}

.ov-grid view {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 0;
}

.ov-grid text {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #1A1A1A;
  font-size: 30rpx;
  font-weight: 800;
}

.ov-grid label {
  margin-top: 8rpx;
  color: #8C8C8C;
  font-size: 21rpx;
}

/* Management entries */
.entry-grid {
  display: flex;
  gap: 22rpx;
}

.entry-card {
  flex: 1;
  min-width: 0;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(201, 162, 39, 0.08);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
  box-sizing: border-box;
}

.entry-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
}

.entry-icon .iconfont {
  font-size: 42rpx;
}

.entry-icon.blue {
  color: #C9A227;
  background: linear-gradient(145deg, #FFF9E6, #FFF0CC);
}

.entry-icon.gold {
  color: #C9A227;
  background: linear-gradient(145deg, #FFF9E6, #FFF0CC);
}

.entry-icon.navy {
  color: #C9A227;
  background: linear-gradient(145deg, #FFF9E6, #FFF0CC);
}

.entry-name {
  margin-top: 18rpx;
  color: #1A1A1A;
  font-size: 30rpx;
  font-weight: 800;
}

.entry-sub {
  margin-top: 8rpx;
  color: #8C8C8C;
  font-size: 22rpx;
}

.entry-row {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
  padding: 26rpx 28rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(201, 162, 39, 0.08);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.entry-row .entry-icon {
  flex: 0 0 76rpx;
  margin-right: 22rpx;
}

.entry-row-main {
  flex: 1;
  min-width: 0;
}

.entry-row .entry-name {
  margin-top: 0;
}

.entry-arrow {
  flex: 0 0 auto;
  color: #C0C9D6;
  font-size: 40rpx;
}

/* Total card */
.total-card {
  display: flex;
  margin-top: 24rpx;
  padding: 30rpx 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #1A1F36 0%, #2D3561 100%);
  box-shadow: 0 12rpx 36rpx rgba(26, 31, 54, 0.16);
}

.total-card view {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.total-card view + view {
  border-left: 1rpx solid rgba(255, 255, 255, 0.14);
}

.total-card text {
  color: #D4AF37;
  font-size: 36rpx;
  font-weight: 900;
}

.total-card label {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.75);
  font-size: 21rpx;
}
