<view class="page">
  <jc-auth-sync></jc-auth-sync>

  <view class="hero">
    <view class="hero-orbit hero-orbit-a"></view>
    <view class="hero-orbit hero-orbit-b"></view>
    <view class="hero-spark hero-spark-1"></view>
    <view class="hero-spark hero-spark-2"></view>
    <view class="hero-spark hero-spark-3"></view>
    <view class="hero-art">
      <view class="art-crown"><text class="iconfont icon-huangguan4"></text></view>
      <view class="art-shop"><text class="iconfont icon-dianpu2"></text></view>
      <view class="art-shield"><text class="iconfont icon-shenhetongguo"></text></view>
    </view>
    <view class="hero-body">
      <view class="hero-kicker">商家工作台</view>
      <view class="hero-title">{{merchantName || '锦程数码'}}</view>
      <view class="hero-role">{{isManager ? '商家负责人' : '核销员'}}</view>
      <view class="hero-desc">今日经营概览 · 快速核销 · 管理入口</view>
    </view>
  </view>

  <view class="verify-entry" bindtap="openVerify">
    <view class="ve-icon"><text class="iconfont icon-hexiaoma"></text></view>
    <view class="ve-main">
      <view class="ve-title">统一核销</view>
      <view class="ve-sub">支持现金券和积分礼品核销</view>
    </view>
    <view class="ve-action">扫一扫 ›</view>
  </view>

  <view class="section-title">今日概览</view>
  <view class="overview-card">
    <view class="ov-main">
      <view class="ov-label">今日核销金额</view>
      <view class="ov-value">￥{{todayAmount}}</view>
      <view class="ov-desc">{{todayCount}} 笔核销</view>
    </view>
    <view class="ov-grid">
      <view>
        <text>￥{{weekAmount}}</text>
        <label>本周</label>
      </view>
      <view>
        <text>￥{{monthAmount}}</text>
        <label>本月</label>
      </view>
    </view>
  </view>

  <view class="section-title">管理入口</view>
  <view class="entry-grid">
    <view class="entry-card" bindtap="goRecords">
      <view class="entry-icon blue"><text class="iconfont icon-xiaofeijilu1"></text></view>
      <view class="entry-name">核销明细</view>
      <view class="entry-sub">查看顾客、金额、核销员</view>
    </view>
    <view wx:if="{{isManager}}" class="entry-card" bindtap="goStaff">
      <view class="entry-icon gold"><text class="iconfont icon-yonghu"></text></view>
      <view class="entry-name">核销员管理</view>
      <view class="entry-sub">{{staffCount}} 名核销员统计</view>
    </view>
  </view>

  <view wx:if="{{isManager}}" class="entry-row" bindtap="goWithdraw">
    <view class="entry-icon navy"><text class="iconfont icon-jintuikuan"></text></view>
    <view class="entry-row-main">
      <view class="entry-name">提现管理</view>
      <view class="entry-sub">可提现 ￥{{availableAmount}} · 提现中 ￥{{withdrawingAmount}}</view>
    </view>
    <view class="entry-arrow">›</view>
  </view>

  <view class="total-card">
    <view>
      <text>￥{{totalAmount}}</text>
      <label>累计核销</label>
    </view>
    <view>
      <text>{{verifyCount}}</text>
      <label>累计笔数</label>
    </view>
    <view>
      <text>{{customerCount}}</text>
      <label>服务顾客</label>
    </view>
  </view>
</view>
