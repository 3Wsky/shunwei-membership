<view class="page">
  <jc-auth-sync></jc-auth-sync>

  <view class="hero">
    <view class="hero-badge">SN 码绑定</view>
    <view class="hero-title">{{ocrEnabled ? '拍照识别序列号' : '手动录入 SN 码'}}</view>
    <view class="hero-desc">{{ocrEnabled ? '拍摄手机包装上的 SN 标签，自动识别序列号' : '请手动输入产品 SN 序列号，拍照识别功能暂时关闭'}}</view>
  </view>

  <view wx:if="{{ocrEnabled}}" class="action-area">
    <view class="photo-btn {{scanning ? 'disabled' : ''}}" bindtap="takePhoto">
      <text class="iconfont icon-hexiaoma"></text> 拍照识别
    </view>
  </view>

  <view class="result-card">
    <view class="rc-head">{{ocrEnabled ? '识别结果' : '录入信息'}}</view>
    <view class="rc-row">
      <text class="rc-label">SN 码</text>
      <input class="rc-input" value="{{form.sn}}" bindinput="editSn" placeholder="请输入 SN 序列号" />
    </view>
    <view class="rc-row">
      <text class="rc-label">品牌</text>
      <input wx:if="{{!ocrEnabled}}" class="rc-input" value="{{form.brand}}" bindinput="editBrand" placeholder="选填" />
      <text wx:else class="rc-value">{{form.brand || '—'}}</text>
    </view>
    <view class="rc-row">
      <text class="rc-label">型号</text>
      <input wx:if="{{!ocrEnabled}}" class="rc-input" value="{{form.model}}" bindinput="editModel" placeholder="选填" />
      <text wx:else class="rc-value">{{form.model || '—'}}</text>
    </view>

    <view class="bind-section">
      <view class="rc-row">
        <text class="rc-label">关联订单</text>
        <input class="rc-input" value="{{orderId}}" bindinput="editOrder" placeholder="输入订单号（可选）" />
      </view>
      <view class="bind-btn {{!form.sn ? 'disabled' : ''}}" bindtap="bindSn">
        确认绑定
      </view>
    </view>
  </view>

  <view wx:if="{{history.length}}" class="section-title">
    <text>最近绑定记录</text>
    <view class="section-badge">{{history.length}}条</view>
  </view>
  <view wx:if="{{history.length}}" class="record-list">
    <view wx:for="{{history}}" wx:key="id" class="record-row">
      <view class="record-left">
        <view class="record-name">{{item.sn_code}}</view>
        <view class="record-meta">{{item.brand}} {{item.model}}{{item.order_id ? ' · 订单 ' + item.order_id : ''}}</view>
      </view>
      <view class="record-source">{{item.source === 'scan' ? '拍照' : '手动'}}</view>
    </view>
  </view>
</view>
