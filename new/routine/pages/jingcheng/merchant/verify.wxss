.page{min-height:100vh;background:#f5f3f0;padding:24rpx;box-sizing:border-box}.scan-card{display:flex;flex-direction:column;align-items:center;background:linear-gradient(135deg,#1a1f36,#343b62);border-radius:22rpx;padding:48rpx;color:#fff}.icon{font-size:76rpx;color:#e0c568}.scan-card text{font-size:31rpx;font-weight:600;margin-top:10rpx}.scan-card label{font-size:22rpx;color:#b8bbca;margin-top:8rpx}.form{background:#fff;border-radius:20rpx;padding:28rpx;margin-top:20rpx}.field{margin-bottom:25rpx}.field label{display:block;font-size:24rpx;color:#555;margin-bottom:10rpx}.field input{height:76rpx;background:#f7f6f3;border-radius:12rpx;padding:0 18rpx;font-size:27rpx}.submit{background:#1a1f36;color:#e0c568;font-size:28rpx;margin-top:12rpx}.tip{font-size:22rpx;color:#999;line-height:1.7;padding:24rpx}
