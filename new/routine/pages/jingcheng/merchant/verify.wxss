page {
  background: linear-gradient(180deg, #F7FBFF 0%, #EEF5FF 100%);
}

.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 56rpx;
  box-sizing: border-box;
  color: #0B1F3A;
  background:
    radial-gradient(circle at 82% 6%, rgba(77, 155, 255, 0.14), transparent 260rpx),
    linear-gradient(180deg, #F7FBFF 0%, #EEF5FF 100%);
}

/* Hero */
.hero {
  position: relative;
  min-height: 300rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(15, 35, 90, 0.18);
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero-body {
  position: relative;
  z-index: 2;
  padding: 36rpx;
}

.hero-badge {
  display: inline-block;
  padding: 8rpx 22rpx;
  border-radius: 24rpx;
  color: #2A2207;
  font-size: 23rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #F8DC8E, #E6B84E);
}

.hero-title {
  margin-top: 18rpx;
  color: #fff;
  font-size: 46rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 23rpx;
}

.scan-btn {
  display: inline-flex;
  align-items: center;
  margin-top: 26rpx;
  padding: 18rpx 44rpx;
  border-radius: 40rpx;
  color: #2A2207;
  font-size: 30rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #F8DC8E, #E0A93C);
  box-shadow: 0 10rpx 24rpx rgba(180, 130, 30, 0.4);
}

.scan-btn .iconfont {
  margin-right: 10rpx;
  font-size: 34rpx;
}

.scan-btn.disabled {
  opacity: 0.6;
}

/* Personal data card */
.data-card {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.97);
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
}

.dc-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dc-kicker {
  color: #B8862B;
  font-size: 22rpx;
  font-weight: 800;
}

.dc-title {
  margin-top: 6rpx;
  color: #0B1F3A;
  font-size: 30rpx;
  font-weight: 800;
}

.dc-tag {
  display: flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 22rpx;
  color: #1F6BFF;
  font-size: 22rpx;
  font-weight: 700;
  background: #EEF5FF;
}

.dc-tag .iconfont {
  margin-right: 6rpx;
  font-size: 24rpx;
}

.dc-body {
  display: flex;
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #FBF6E9, #FFF9EC);
}

.dc-cell {
  flex: 1;
  min-width: 0;
}

.dc-cell + .dc-cell {
  border-left: 1rpx solid rgba(184, 134, 43, 0.18);
  padding-left: 28rpx;
}

.dc-label {
  color: #9A8A5E;
  font-size: 23rpx;
}

.dc-value {
  margin-top: 12rpx;
  color: #B8862B;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1;
}

.dc-value.dark {
  color: #0B1F3A;
}

/* Section title */
.section-title {
  display: flex;
  align-items: center;
  margin: 32rpx 4rpx 18rpx;
  color: #0B1F3A;
  font-size: 32rpx;
  font-weight: 800;
}

.section-badge {
  margin-left: 10rpx;
  padding: 2rpx 12rpx;
  border-radius: 14rpx;
  color: #8A95A6;
  font-size: 20rpx;
  font-weight: 700;
  background: #EEF1F6;
}

/* Record list */
.record-list {
  overflow: hidden;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.97);
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
}

.record-row {
  display: flex;
  align-items: center;
  min-height: 108rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #F0F4FA;
}

.record-row:last-child {
  border-bottom: 0;
}

.record-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 66rpx;
  height: 66rpx;
  flex: 0 0 66rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  color: #1F6BFF;
  background: #EEF5FF;
}

.record-icon .iconfont {
  font-size: 34rpx;
}

.record-left {
  flex: 1;
  min-width: 0;
}

.record-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #0B1F3A;
  font-size: 28rpx;
  font-weight: 800;
}

.record-meta {
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #8A95A6;
  font-size: 22rpx;
}

.record-amount {
  flex: 0 0 auto;
  margin-left: 16rpx;
  color: #B8862B;
  font-size: 30rpx;
  font-weight: 900;
}

/* Empty */
.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 200rpx;
  border-radius: 24rpx;
  color: #8A95A6;
  font-size: 26rpx;
  background: rgba(255, 255, 255, 0.97);
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 88rpx;
  margin-bottom: 14rpx;
  border-radius: 30rpx;
  color: #82AEFF;
  background: linear-gradient(145deg, #EEF5FF, #FFFFFF);
}

.empty-icon .iconfont {
  font-size: 54rpx;
}

/* Summary */
.summary-card {
  margin-top: 24rpx;
  border-radius: 26rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.97);
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
}

.summary-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 28rpx;
}

.sh-left {
  display: flex;
  align-items: center;
  color: #0B1F3A;
  font-size: 28rpx;
  font-weight: 800;
}

.sh-left .iconfont {
  margin-right: 12rpx;
  color: #1F6BFF;
  font-size: 32rpx;
}

.sh-right {
  color: #8A95A6;
  font-size: 24rpx;
}

.summary-body {
  display: flex;
  padding: 8rpx 0 28rpx;
}

.summary-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.summary-cell + .summary-cell {
  border-left: 1rpx solid #F0F4FA;
}

.sc-label {
  color: #8A95A6;
  font-size: 22rpx;
}

.sc-value {
  margin-top: 12rpx;
  color: #B8862B;
  font-size: 34rpx;
  font-weight: 900;
}

.sc-desc {
  margin-top: 8rpx;
  color: #8A95A6;
  font-size: 21rpx;
}
