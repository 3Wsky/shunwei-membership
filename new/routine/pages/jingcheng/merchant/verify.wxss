page {
  background: linear-gradient(180deg, #F7FBFF 0%, #EEF5FF 100%);
}

.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 56rpx;
  box-sizing: border-box;
  color: #1A1A1A;
  background:
    radial-gradient(circle at 82% 6%, rgba(77, 155, 255, 0.12), transparent 260rpx),
    linear-gradient(180deg, #F7FBFF 0%, #EEF5FF 100%);
}

/* Hero */
.hero {
  position: relative;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #1A1F36 0%, #232A4A 52%, #2D3561 100%);
  box-shadow: 0 16rpx 40rpx rgba(26, 31, 54, 0.28);
}

/* Soft gold glows for depth */
.hero-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(2rpx);
  z-index: 1;
  pointer-events: none;
}

.hero-glow-a {
  top: -120rpx;
  right: -90rpx;
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle, rgba(230, 184, 78, 0.28), rgba(230, 184, 78, 0) 70%);
}

.hero-glow-b {
  bottom: -140rpx;
  left: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(201, 162, 39, 0.18), rgba(201, 162, 39, 0) 70%);
}

/* Right-side art: QR scan frame + gold voucher */
.hero-art {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 200rpx;
  height: 200rpx;
  z-index: 1;
  pointer-events: none;
}

.art-scan {
  position: absolute;
  right: 30rpx;
  top: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 132rpx;
  border-radius: 24rpx;
  color: #DCE6FF;
  background: linear-gradient(150deg, #3B4470, #2A3157);
  box-shadow: inset 0 2rpx 10rpx rgba(255,255,255,0.1), 0 12rpx 26rpx rgba(0,0,0,0.3);
}

.art-scan .iconfont {
  font-size: 84rpx;
  color: #EAF0FF;
}

.scan-corner {
  position: absolute;
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid #F4D58D;
}

.scan-corner.tl { top: 12rpx; left: 12rpx; border-right: 0; border-bottom: 0; border-top-left-radius: 8rpx; }
.scan-corner.tr { top: 12rpx; right: 12rpx; border-left: 0; border-bottom: 0; border-top-right-radius: 8rpx; }
.scan-corner.bl { bottom: 12rpx; left: 12rpx; border-right: 0; border-top: 0; border-bottom-left-radius: 8rpx; }
.scan-corner.br { bottom: 12rpx; right: 12rpx; border-left: 0; border-top: 0; border-bottom-right-radius: 8rpx; }

.scan-line {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  top: 50%;
  height: 3rpx;
  background: linear-gradient(90deg, rgba(244,213,141,0), #F4D58D, rgba(244,213,141,0));
  box-shadow: 0 0 10rpx rgba(244, 213, 141, 0.7);
}

.art-voucher {
  position: absolute;
  right: 0;
  bottom: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  color: #7A5B12;
  background: linear-gradient(135deg, #F8DC8E, #E6B84E);
  box-shadow: 0 8rpx 18rpx rgba(201, 162, 39, 0.4);
  transform: rotate(-10deg);
}

.art-voucher .iconfont {
  font-size: 42rpx;
}

.hero-body {
  position: relative;
  z-index: 2;
  padding: 40rpx;
  padding-right: 210rpx;
}

.button-hover {
  transform: scale(0.97);
  opacity: 0.92;
}

.hero-badge {
  display: inline-block;
  padding: 8rpx 22rpx;
  border-radius: 24rpx;
  color: #2A2207;
  font-size: 23rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #F8DC8E, #E6B84E);
}

.hero-title {
  margin-top: 18rpx;
  color: #fff;
  font-size: 46rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 23rpx;
}

.scan-btn {
  display: inline-flex;
  align-items: center;
  margin-top: 28rpx;
  padding: 20rpx 48rpx;
  border-radius: 40rpx;
  color: #2A2207;
  font-size: 30rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #F8DC8E, #E6B84E);
  box-shadow: 0 8rpx 22rpx rgba(201, 162, 39, 0.34);
  transition: transform 0.18s ease, opacity 0.18s ease;
}

.scan-btn .iconfont {
  margin-right: 10rpx;
  font-size: 34rpx;
}

.scan-btn.disabled {
  opacity: 0.6;
}

/* Manual code card (below hero, light style) */
.manual-card {
  margin-top: 22rpx;
  padding: 26rpx 28rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
}

.manual-label {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
  color: #42526E;
  font-size: 24rpx;
  font-weight: 700;
}

.manual-label .iconfont {
  margin-right: 10rpx;
  color: #1F6BFF;
  font-size: 28rpx;
}

.manual-input-row {
  display: flex;
  align-items: center;
}

.code-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: #F7F9FC;
  border: 2rpx solid #E6EEF8;
  color: #0B1F3A;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  text-align: center;
  margin-right: 16rpx;
}

.code-input-ph {
  color: #AEB8C8;
  letter-spacing: 2rpx;
  font-size: 26rpx;
  font-weight: 400;
}

.manual-btn {
  padding: 0 38rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #E6B84E, #C9A227);
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  white-space: nowrap;
  transition: transform 0.18s ease, opacity 0.18s ease;
}

.manual-btn.disabled {
  opacity: 0.45;
}

/* Personal data card */
.data-card {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
}

.dc-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dc-kicker {
  color: #C9A227;
  font-size: 22rpx;
  font-weight: 800;
}

.dc-title {
  margin-top: 6rpx;
  color: #1A1A1A;
  font-size: 30rpx;
  font-weight: 800;
}

.dc-tag {
  display: flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 22rpx;
  color: #1F6BFF;
  font-size: 22rpx;
  font-weight: 700;
  background: #EEF5FF;
}

.dc-tag .iconfont {
  margin-right: 6rpx;
  font-size: 24rpx;
}

.dc-body {
  display: flex;
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #FBF8F5, #FFFDF9);
  border: 1rpx solid rgba(201, 162, 39, 0.1);
}

.dc-cell {
  flex: 1;
  min-width: 0;
}

.dc-cell + .dc-cell {
  border-left: 1rpx solid rgba(201, 162, 39, 0.15);
  padding-left: 28rpx;
}

.dc-label {
  color: #8C7355;
  font-size: 23rpx;
}

.dc-value {
  margin-top: 12rpx;
  color: #C9A227;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1;
}

.dc-value.dark {
  color: #1A1A1A;
}

/* Section title */
.section-title {
  display: flex;
  align-items: center;
  margin: 32rpx 4rpx 18rpx;
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 800;
}

.section-badge {
  margin-left: 10rpx;
  padding: 2rpx 12rpx;
  border-radius: 14rpx;
  color: #1F6BFF;
  font-size: 20rpx;
  font-weight: 700;
  background: #EEF5FF;
}

/* Record list */
.record-list {
  overflow: hidden;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
}

.record-row {
  display: flex;
  align-items: center;
  min-height: 108rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #F0F4FA;
}

.record-row:last-child {
  border-bottom: 0;
}

.record-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 66rpx;
  height: 66rpx;
  flex: 0 0 66rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  color: #1F6BFF;
  background: #EEF5FF;
}

.record-icon .iconfont {
  font-size: 34rpx;
}

.record-left {
  flex: 1;
  min-width: 0;
}

.record-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #1A1A1A;
  font-size: 28rpx;
  font-weight: 800;
}

.record-meta {
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #8C8C8C;
  font-size: 22rpx;
}

.record-amount {
  flex: 0 0 auto;
  margin-left: 16rpx;
  color: #C9A227;
  font-size: 30rpx;
  font-weight: 900;
}

/* Empty */
.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 200rpx;
  border-radius: 24rpx;
  color: #8A95A6;
  font-size: 26rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 88rpx;
  margin-bottom: 14rpx;
  border-radius: 30rpx;
  color: #82AEFF;
  background: linear-gradient(145deg, #EEF5FF, #FFFFFF);
}

.empty-icon .iconfont {
  font-size: 54rpx;
}

/* Summary */
.summary-card {
  margin-top: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #FFFFFF;
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
}

.summary-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 28rpx;
}

.sh-left {
  display: flex;
  align-items: center;
  color: #1A1A1A;
  font-size: 28rpx;
  font-weight: 800;
}

.sh-left .iconfont {
  margin-right: 12rpx;
  color: #1F6BFF;
  font-size: 32rpx;
}

.sh-right {
  color: #8C8C8C;
  font-size: 24rpx;
}

.summary-body {
  display: flex;
  padding: 8rpx 0 28rpx;
}

.summary-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.summary-cell + .summary-cell {
  border-left: 1rpx solid #F0F4FA;
}

.sc-label {
  color: #8C8C8C;
  font-size: 22rpx;
}

.sc-value {
  margin-top: 12rpx;
  color: #C9A227;
  font-size: 34rpx;
  font-weight: 900;
}

.sc-desc {
  margin-top: 8rpx;
  color: #8C8C8C;
  font-size: 21rpx;
}
