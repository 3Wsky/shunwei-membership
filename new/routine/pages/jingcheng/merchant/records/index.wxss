page {
  background: linear-gradient(180deg, #F7FBFF 0%, #EEF5FF 100%);
}

.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 56rpx;
  box-sizing: border-box;
  color: #0B1F3A;
  background:
    radial-gradient(circle at 82% 6%, rgba(77, 155, 255, 0.14), transparent 260rpx),
    linear-gradient(180deg, #F7FBFF 0%, #EEF5FF 100%);
}

.hero-card,
.summary-card,
.record-list,
.empty-card {
  border: 1rpx solid rgba(230, 238, 248, 0.9);
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 70, 0.06);
}

.hero-card {
  padding: 30rpx;
  border-radius: 32rpx;
}

.hero-kicker {
  color: #B8862B;
  font-size: 24rpx;
  font-weight: 800;
}

.hero-title {
  margin-top: 10rpx;
  color: #0B1F3A;
  font-size: 38rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 12rpx;
  color: #8A95A6;
  font-size: 24rpx;
}

.summary-card {
  display: flex;
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  box-sizing: border-box;
}

.summary-main {
  flex: 1;
  min-width: 0;
}

.summary-label,
.summary-desc {
  color: #8A95A6;
  font-size: 24rpx;
}

.summary-value {
  margin: 14rpx 0 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #B8862B;
  font-size: 50rpx;
  font-weight: 900;
  line-height: 1;
}

.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  width: 300rpx;
  margin-left: 22rpx;
  border-left: 1rpx solid #E6EEF8;
}

.summary-grid view {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 0;
}

.summary-grid text {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #0B1F3A;
  font-size: 26rpx;
  font-weight: 900;
}

.summary-grid label {
  margin-top: 8rpx;
  color: #8A95A6;
  font-size: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin: 32rpx 4rpx 18rpx;
  color: #0B1F3A;
  font-size: 32rpx;
  font-weight: 800;
}

.section-badge {
  margin-left: 10rpx;
  padding: 2rpx 12rpx;
  border-radius: 14rpx;
  color: #1F6BFF;
  font-size: 20rpx;
  font-weight: 700;
  background: #EEF5FF;
}

.record-list {
  overflow: hidden;
  border-radius: 24rpx;
}

.record-row {
  display: flex;
  align-items: center;
  min-height: 112rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #F0F4FA;
}

.record-row:last-child {
  border-bottom: 0;
}

.record-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 66rpx;
  height: 66rpx;
  flex: 0 0 66rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  color: #1F6BFF;
  background: #EEF5FF;
}

.record-icon .iconfont {
  font-size: 34rpx;
}

.record-left {
  flex: 1;
  min-width: 0;
}

.record-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #0B1F3A;
  font-size: 28rpx;
  font-weight: 800;
}

.record-meta,
.record-remark {
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #8A95A6;
  font-size: 22rpx;
}

.record-remark {
  color: #42526E;
}

.record-amount {
  flex: 0 0 auto;
  margin-left: 16rpx;
  color: #B8862B;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 200rpx;
  border-radius: 24rpx;
  color: #8A95A6;
  font-size: 26rpx;
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 88rpx;
  margin-bottom: 14rpx;
  border-radius: 30rpx;
  color: #82AEFF;
  background: linear-gradient(145deg, #EEF5FF, #FFFFFF);
}

.empty-icon .iconfont {
  font-size: 54rpx;
}
