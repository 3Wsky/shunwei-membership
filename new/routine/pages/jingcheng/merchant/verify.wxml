<view class="page">
  <jc-auth-sync></jc-auth-sync>

  <view class="hero">
    <view class="hero-glow hero-glow-a"></view>
    <view class="hero-glow hero-glow-b"></view>
    <view class="hero-art">
      <view class="art-scan">
        <view class="scan-corner tl"></view>
        <view class="scan-corner tr"></view>
        <view class="scan-corner bl"></view>
        <view class="scan-corner br"></view>
        <text class="iconfont icon-erweima3"></text>
        <view class="scan-line"></view>
      </view>
      <view class="art-voucher"><text class="iconfont icon-youhuiquan2"></text></view>
    </view>
    <view class="hero-body">
      <view class="hero-badge"><text class="iconfont icon-shengqian"></text> 现金券核销</view>
      <view class="hero-title">扫描顾客付款码</view>
      <view class="hero-desc">请让顾客打开现金券钱包，出示付款码</view>
      <view class="scan-btn {{scanning ? 'disabled' : ''}}" hover-class="button-hover" bindtap="scanCustomer">
        <text class="iconfont icon-saoyisao"></text> 扫一扫
      </view>
    </view>
  </view>

  <view class="manual-card">
    <view class="manual-label"><text class="iconfont icon-erweima3"></text> 手动输入核销码</view>
    <view class="manual-input-row">
      <input class="code-input" type="number" maxlength="6" placeholder="输入 6 位核销码" value="{{manualCode}}" bindinput="onManualInput" placeholder-class="code-input-ph" />
      <view class="manual-btn {{!manualCode ? 'disabled' : ''}}" hover-class="button-hover" bindtap="manualVerify">核销</view>
    </view>
  </view>

  <view class="data-card">
    <view class="dc-head">
      <view>
        <view class="dc-kicker">我的今日核销</view>
        <view class="dc-title">当前核销员数据</view>
      </view>
      <view class="dc-tag"><text class="iconfont icon-yonghu"></text> 个人</view>
    </view>
    <view class="dc-body">
      <view class="dc-cell">
        <view class="dc-label">今日金额</view>
        <view class="dc-value">￥{{todayAmount}}</view>
      </view>
      <view class="dc-cell">
        <view class="dc-label">核销次数</view>
        <view class="dc-value dark">{{todayCount}}</view>
      </view>
    </view>
  </view>

  <view class="section-title">
    <text>今日核销明细</text>
    <view class="section-badge">{{todayRecords.length}}条</view>
  </view>
  <view wx:if="{{todayRecords.length}}" class="record-list">
    <view wx:for="{{todayRecords}}" wx:key="id" class="record-row">
      <view class="record-icon"><text class="iconfont icon-yonghu"></text></view>
      <view class="record-left">
        <view class="record-name">{{item.customerNickname || ('UID ' + item.customerUid)}}</view>
        <view class="record-meta">{{item.timeText}}{{item.remark ? ' · ' + item.remark : ''}}</view>
      </view>
      <view class="record-amount">-￥{{item.amount}}</view>
    </view>
  </view>
  <view wx:else class="empty-card">
    <view class="empty-icon"><text class="iconfont icon-hexiaoma"></text></view>
    <view>今日暂无核销明细</view>
  </view>

  <view class="summary-card">
    <view class="summary-head" bindtap="toggleSummary">
      <view class="sh-left"><text class="iconfont icon-xiaofeijilu1"></text> 日 / 周 / 月汇总</view>
      <view class="sh-right">{{showSummary ? '收起' : '展开'}} {{showSummary ? '⌃' : '⌄'}}</view>
    </view>
    <view wx:if="{{showSummary}}" class="summary-body">
      <view class="summary-cell">
        <view class="sc-label">日汇总</view>
        <view class="sc-value">￥{{todayAmount}}</view>
        <view class="sc-desc">{{todayCount}} 次</view>
      </view>
      <view class="summary-cell">
        <view class="sc-label">周汇总</view>
        <view class="sc-value">￥{{weekAmount}}</view>
        <view class="sc-desc">{{weekCount}} 次</view>
      </view>
      <view class="summary-cell">
        <view class="sc-label">月汇总</view>
        <view class="sc-value">￥{{monthAmount}}</view>
        <view class="sc-desc">{{monthCount}} 次</view>
      </view>
    </view>
  </view>
</view>

<view wx:if="{{showAmountModal}}" class="vmodal-mask" catchtouchmove="preventMove">
  <view class="vmodal">
    <view class="vmodal-head">
      <view class="vmodal-ic"><text class="iconfont icon-shengqian"></text></view>
      <view class="vmodal-htxt">
        <view class="vmodal-title">现金券核销</view>
        <view class="vmodal-sub">顾客：{{pendingInfo.nickname || ('UID ' + pendingInfo.uid)}}</view>
      </view>
    </view>

    <view class="balance-card">
      <view class="balance-card-k">顾客可用现金券余额</view>
      <view class="balance-card-v">
        <text class="balance-card-yen">¥</text>{{pendingInfo.balance}}
      </view>
    </view>

    <view class="amount-label">
      <text>本次核销金额</text>
      <text class="amount-all" bindtap="useFullBalance">全部核销</text>
    </view>
    <view class="amount-field">
      <text class="amount-yen">¥</text>
      <input class="amount-input" type="digit" focus="{{showAmountModal}}" value="{{amountInput}}" bindinput="onAmountInput" placeholder="0.00" placeholder-class="amount-ph" />
    </view>
    <view class="amount-hint" wx:if="{{verifyMode === 'hundred'}}"><text class="iconfont icon-tishi"></text> 当前为整百核销模式，仅支持 100、200 等整百金额</view>
    <view class="amount-hint" wx:else><text class="iconfont icon-tishi"></text> 支持整数或两位小数，如 212 或 212.33</view>
    <view class="vmodal-actions">
      <view class="vmodal-btn cancel" hover-class="button-hover" bindtap="closeAmountModal">取消</view>
      <view class="vmodal-btn confirm" hover-class="button-hover" bindtap="confirmAmount">确认核销</view>
    </view>
  </view>
</view>

<view wx:if="{{showIntegralModal}}" class="vmodal-mask" catchtouchmove="preventMove">
  <view class="vmodal">
    <view class="vmodal-head">
      <view class="vmodal-ic gift"><text class="iconfont icon-liwu"></text></view>
      <view class="vmodal-htxt">
        <view class="vmodal-title">积分礼品核销</view>
        <view class="vmodal-sub">顾客：{{integralInfo.customerNickname || ('UID ' + integralInfo.customerUid)}}</view>
      </view>
    </view>

    <view class="gift-card">
      <view class="gift-row"><text class="gift-k">兑换礼品</text><text class="gift-v">{{integralInfo.productName}}</text></view>
      <view class="gift-row"><text class="gift-k">消耗积分</text><text class="gift-v gold">{{integralInfo.integralCost}}</text></view>
    </view>

    <view class="amount-hint"><text class="iconfont icon-tishi"></text> 确认无误后点击核销，核销后不可撤销</view>
    <view class="vmodal-actions">
      <view class="vmodal-btn cancel" hover-class="button-hover" bindtap="closeIntegralModal">取消</view>
      <view class="vmodal-btn confirm" hover-class="button-hover" bindtap="confirmIntegralVerify">确认核销</view>
    </view>
  </view>
</view>
