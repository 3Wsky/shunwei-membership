page { background: #F5F3F0; }
.page { min-height: 100vh; padding: 28rpx 32rpx 56rpx; box-sizing: border-box; color: #1A1A1A; }

.hero {
  padding: 36rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #8B0000, #B22222);
  color: #fff;
  margin-bottom: 24rpx;
}
.hero-badge {
  display: inline-block;
  padding: 8rpx 22rpx;
  border-radius: 24rpx;
  color: #fff;
  font-size: 23rpx;
  font-weight: 800;
  background: rgba(255,255,255,0.2);
}
.hero-title { margin-top: 14rpx; font-size: 36rpx; font-weight: 900; }

.card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
  margin-bottom: 24rpx;
  overflow: hidden;
}
.section { padding: 24rpx 28rpx; }
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.refresh-btn { font-size: 24rpx; color: #C9A227; font-weight: 500; }

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
}

.approval-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.approval-item:last-child { border-bottom: none; }
.ai-top { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.ai-id { font-size: 26rpx; font-weight: 700; color: #333; }
.ai-tier { font-size: 22rpx; color: #C9A227; background: #FFF9ED; padding: 4rpx 12rpx; border-radius: 8rpx; }
.ai-row { display: flex; align-items: center; padding: 6rpx 0; font-size: 26rpx; color: #666; }
.ai-label { width: 120rpx; color: #999; font-size: 24rpx; flex-shrink: 0; }
.ai-actions { display: flex; gap: 16rpx; margin-top: 16rpx; }
.ai-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
}
.ai-btn.approve { background: linear-gradient(135deg, #1A1F36, #2D3555); color: #F8DC8E; }
.ai-btn.reject { background: #f5f5f5; color: #E34D59; }

.empty-hint { text-align: center; color: #ccc; padding: 40rpx 0; font-size: 26rpx; }

.spread-form { padding: 8rpx 0; }
.form-row { display: flex; align-items: center; padding: 16rpx 0; }
.form-label { width: 200rpx; font-size: 26rpx; color: #666; flex-shrink: 0; }
.form-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
}
.form-btn {
  margin-top: 24rpx;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #8B0000, #B22222);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}
