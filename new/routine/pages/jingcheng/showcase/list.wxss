.page { min-height: 100vh; padding: 24rpx; background: #f5f5f5; box-sizing: border-box; }
.tip { font-size: 24rpx; color: #888; margin-bottom: 20rpx; }
.grid { display: flex; flex-wrap: wrap; gap: 20rpx; }
.card { width: calc(50% - 10rpx); background: #fff; border-radius: 16rpx; overflow: hidden; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); }
.cover { width: 100%; height: 280rpx; display: block; background: #eee; }
.cover.placeholder { display: flex; align-items: center; justify-content: center; color: #aaa; font-size: 28rpx; }
.name { padding: 16rpx 16rpx 8rpx; font-size: 26rpx; color: #222; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.price { padding: 0 16rpx 16rpx; font-size: 30rpx; font-weight: 700; color: #c9a962; }
.empty, .loading { text-align: center; color: #999; padding: 120rpx 0; font-size: 28rpx; }
.link-btn { margin-top: 24rpx; font-size: 26rpx; background: #1a1f36; color: #fff; border-radius: 999rpx; }
