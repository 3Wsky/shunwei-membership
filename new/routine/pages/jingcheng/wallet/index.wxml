<view class="page">
  <view class="balance">
    <view class="bal-watermark"><text class="iconfont icon-yue2"></text></view>
    <view class="bal-label">现金券可用余额</view>
    <view class="bal-value">￥{{balance}}</view>
    <view class="bal-sub">有效期内可用，过期自动失效</view>
    <view class="bal-totals">
      <view><text>￥{{totalGranted}}</text><label>累计获得</label></view>
      <view><text>￥{{totalUsed}}</text><label>累计核销</label></view>
    </view>
  </view>

  <block wx:if="{{balance > 0}}">
    <view wx:if="{{termsAgreed}}" class="pay-card">
      <view class="pay-title">出示付款码核销现金券</view>
      <view class="pay-qr">
        <zb-code wx:if="{{qrText}}" cid="wallet-pay-qr" val="{{qrText}}" size="320" load-make="{{true}}" foreground="#0B1F3A" background="#ffffff"></zb-code>
        <view wx:else class="pay-loading">{{payLoading ? '生成中…' : '点击下方刷新生成付款码'}}</view>
      </view>
      <view wx:if="{{qrText}}" class="pay-hint">商家/店员扫码核销 · {{payCountdown}}s 后自动刷新</view>
      <view class="pay-refresh" bindtap="refreshCode"><text class="iconfont icon-shuaxin"></text> 刷新付款码</view>
      <view class="pay-terms" bindtap="openTerms">《现金券使用须知》</view>
    </view>
    <view wx:else class="lock-card" bindtap="openTerms">
      <view class="lock-ic"><text class="iconfont icon-shoudanyouhui"></text></view>
      <view class="lock-title">使用前需阅读并同意</view>
      <view class="lock-sub">点击查看《现金券使用须知》</view>
    </view>
  </block>
  <view wx:else class="empty-balance">
    <view class="eb-title">暂无可用余额</view>
    <view class="eb-sub">当前现金券余额为 0，无法生成付款码</view>
  </view>

  <view wx:if="{{showTerms}}" class="terms-mask" catchtouchmove="true">
    <view class="terms-sheet">
      <view class="terms-title">现金券使用须知</view>
      <view class="terms-tip">请阅读以下条款，同意后方可使用现金券</view>
      <scroll-view scroll-y="true" class="terms-body">
        <view wx:for="{{termsList}}" wx:key="*this" class="terms-item">
          <text class="terms-idx">{{index + 1}}.</text>
          <text class="terms-text">{{item}}</text>
        </view>
      </scroll-view>
      <button class="terms-agree-btn {{countdown > 0 ? 'disabled' : ''}}" disabled="{{countdown > 0}}" bindtap="agreeTerms">
        {{countdown > 0 ? '请阅读（' + countdown + 's）' : '我已阅读并同意'}}
      </button>
    </view>
  </view>

  <view class="title"><text>可核销商家</text><label>{{merchants.length}} 家</label></view>
  <view wx:for="{{merchants}}" wx:key="id" class="merchant-card" data-index="{{index}}" bindtap="openMerchantDetail">
    <view class="mc-head">
      <view class="mc-name">{{item.merchantName}}</view>
      <view class="mc-arrow">›</view>
    </view>
    <view class="mc-badge">当前权益商家</view>
    <view class="mc-row"><text class="mc-k">行业</text><text class="mc-v">{{item.category || '数码3C'}}</text></view>
    <view class="mc-row"><text class="mc-k">营业时间</text><text class="mc-v">{{item.businessHours || '营业时间请咨询'}}</text></view>
    <view class="mc-row"><text class="mc-k">门店地址</text><text class="mc-v">{{item.storeAddress || '门店地址请咨询'}}</text></view>
  </view>
  <view wx:if="{{!loading && !merchants.length}}" class="section-empty">暂无可核销商家</view>

  <view class="promo">
    <view class="promo-title">更多权益商家正在加入中</view>
    <view class="promo-sub">商超、加油站、餐饮等场景陆续接入，敬请期待</view>
    <view class="promo-row">
      <view class="promo-cell"><view class="promo-ic"><text class="iconfont icon-gouwuche11"></text></view><view class="promo-name">商超</view><view class="promo-soon">敬请期待</view></view>
      <view class="promo-cell"><view class="promo-ic"><text class="iconfont icon-dianpu2"></text></view><view class="promo-name">加油站</view><view class="promo-soon">敬请期待</view></view>
      <view class="promo-cell"><view class="promo-ic"><text class="iconfont icon-liwu"></text></view><view class="promo-name">餐饮</view><view class="promo-soon">敬请期待</view></view>
    </view>
  </view>

  <view class="title"><text>核销记录</text><label>最近50条</label></view>
  <view wx:if="{{verifyRecords.length}}" class="card-list">
    <view wx:for="{{verifyRecords}}" wx:key="id" class="ledger">
      <view><text>{{item.merchantName || item.remark || '现金券核销'}}</text><label>{{item.createdText}}{{item.remark ? ' · ' + item.remark : ''}}</label></view>
      <text class="minus">-￥{{item.amount}}</text>
    </view>
  </view>
  <view wx:else class="section-empty">暂无核销记录</view>

  <view class="title"><text>可用现金券</text><label>{{batches.length}} 个批次</label></view>
  <view wx:if="{{batches.length}}" class="card-list">
    <view wx:for="{{batches}}" wx:key="id" class="item">
      <view><text>￥{{item.remainAmount}}</text><label>原金额 ￥{{item.totalAmount}}</label></view>
      <view class="date">有效期至 {{item.expireText}}</view>
    </view>
  </view>
  <view wx:else class="section-empty">暂无可用现金券</view>
</view>
