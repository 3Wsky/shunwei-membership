page {
  background: #F5F3F0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 54rpx;
  box-sizing: border-box;
  color: #1A1A1A;
  background: #F5F3F0;
}

.store-gallery {
  width: 100%;
  height: 360rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.1);
}

.store-gallery-img {
  width: 100%;
  height: 360rpx;
  background: #F0F0F0;
}

.merchant-head {
  padding: 34rpx 32rpx;
  border-radius: 24rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #1A1F36 0%, #2D3561 100%);
  box-shadow: 0 12rpx 36rpx rgba(26, 31, 54, 0.16);
}

.head-label {
  display: inline-flex;
  height: 38rpx;
  align-items: center;
  padding: 0 14rpx;
  border-radius: 19rpx;
  color: #8C7355;
  font-size: 22rpx;
  background: #FBF8F5;
}

.merchant-name {
  margin-top: 24rpx;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.25;
}

.merchant-sub {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 26rpx;
}

.info-card,
.benefit-card {
  margin-top: 24rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(201, 162, 39, 0.08);
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.card-title {
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 0;
  border-top: 1rpx solid #F0F4FA;
}

.info-row label {
  width: 150rpx;
  flex: 0 0 150rpx;
  color: #8C8C8C;
  font-size: 26rpx;
}

.info-row text {
  flex: 1;
  color: #1A1A1A;
  font-size: 27rpx;
  line-height: 1.5;
}

.benefit-line {
  color: #C9A227;
  font-size: 28rpx;
  font-weight: 700;
}

.benefit-desc {
  margin-top: 14rpx;
  color: #8C8C8C;
  font-size: 25rpx;
  line-height: 1.6;
}

.actions {
  display: flex;
  margin-top: 30rpx;
}

.actions button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  color: #C9A227;
  font-size: 30rpx;
  font-weight: 700;
  background: #FFFFFF;
  border: 2rpx solid #C9A227;
}

.actions button + button {
  margin-left: 18rpx;
}

.actions button::after {
  border: 0;
}

.actions .primary {
  color: #FFFFFF;
  border: 0;
  background: linear-gradient(135deg, #E6B84E, #C9A227);
  box-shadow: 0 6rpx 16rpx rgba(201, 162, 39, 0.2);
}
