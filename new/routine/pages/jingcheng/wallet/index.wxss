page {
  background: #F5F3F0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 60rpx;
  box-sizing: border-box;
  color: #1A1A1A;
  background: #F5F3F0;
}

/* Balance */
.balance {
  position: relative;
  overflow: hidden;
  padding: 40rpx 36rpx;
  border-radius: 24rpx;
  color: #fff;
  background: linear-gradient(135deg, #1A1F36 0%, #2D3561 100%);
  box-shadow: 0 12rpx 36rpx rgba(26, 31, 54, 0.16);
}

.bal-watermark {
  position: absolute;
  top: 20rpx;
  right: 26rpx;
  opacity: 0.18;
}

.bal-watermark .iconfont {
  font-size: 150rpx;
  color: #fff;
}

.bal-label {
  position: relative;
  z-index: 2;
  font-size: 25rpx;
  color: rgba(255, 255, 255, 0.85);
}

.bal-value {
  position: relative;
  z-index: 2;
  margin: 14rpx 0 10rpx;
  font-size: 66rpx;
  font-weight: 900;
  line-height: 1;
  color: #D4AF37;
}

.bal-sub {
  position: relative;
  z-index: 2;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

.bal-totals {
  display: flex;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.18);
}

.bal-totals > view {
  width: 50%;
  display: flex;
  flex-direction: column;
}

.bal-totals > view + view {
  padding-left: 36rpx;
  border-left: 1rpx solid rgba(255, 255, 255, 0.18);
}

.bal-totals text {
  font-size: 32rpx;
  font-weight: 800;
  color: #D4AF37;
}

.bal-totals label {
  margin-top: 6rpx;
  font-size: 21rpx;
  color: rgba(255, 255, 255, 0.75);
}

/* Pay code */
.pay-card {
  margin-top: 22rpx;
  padding: 36rpx 28rpx 30rpx;
  border-radius: 24rpx;
  text-align: center;
  background: #FFFFFF;
  border: 1rpx solid rgba(201, 162, 39, 0.08);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.pay-title {
  color: #1A1A1A;
  font-size: 30rpx;
  font-weight: 800;
}

.pay-qr {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 340rpx;
  margin: 24rpx 0 16rpx;
}

.pay-loading {
  color: #8C8C8C;
  font-size: 26rpx;
}

.pay-hint {
  color: #8C8C8C;
  font-size: 23rpx;
}

.pay-refresh {
  display: inline-flex;
  align-items: center;
  margin-top: 22rpx;
  padding: 14rpx 40rpx;
  border-radius: 36rpx;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #E6B84E, #C9A227);
  box-shadow: 0 4rpx 12rpx rgba(201, 162, 39, 0.2);
}

.pay-refresh .iconfont {
  margin-right: 10rpx;
  font-size: 28rpx;
}

.pay-terms {
  margin-top: 20rpx;
  color: #C9A227;
  font-size: 22rpx;
  text-decoration: underline;
}

.lock-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 22rpx;
  padding: 50rpx 28rpx;
  border-radius: 24rpx;
  text-align: center;
  background: #FFFFFF;
  border: 1rpx dashed rgba(201, 162, 39, 0.45);
}

.lock-ic {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 16rpx;
  border-radius: 28rpx;
  color: #C9A227;
  background: linear-gradient(145deg, #FFF9E6, #FFF0CC);
}

.lock-ic .iconfont {
  font-size: 50rpx;
}

.lock-title {
  color: #1A1A1A;
  font-size: 28rpx;
  font-weight: 800;
}

.lock-sub {
  margin-top: 8rpx;
  color: #C9A227;
  font-size: 23rpx;
}

.empty-balance {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 22rpx;
  padding: 52rpx 28rpx;
  border-radius: 24rpx;
  text-align: center;
  background: #FFFFFF;
  border: 1rpx solid rgba(201, 162, 39, 0.08);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.eb-title {
  color: #1A1A1A;
  font-size: 30rpx;
  font-weight: 800;
}

.eb-sub {
  margin-top: 12rpx;
  color: #8C8C8C;
  font-size: 24rpx;
}

/* Section title */
.title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 34rpx 6rpx 18rpx;
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 800;
}

.title label {
  font-size: 21rpx;
  font-weight: 400;
  color: #8C8C8C;
}

/* Merchant card (vertical) */
.merchant-card {
  margin-bottom: 18rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(201, 162, 39, 0.08);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.mc-cover {
  display: block;
  width: 100%;
  height: 280rpx;
  margin-bottom: 20rpx;
  border-radius: 18rpx;
  background: #F0F0F0;
}

.mc-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.mc-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 900;
}

.mc-arrow {
  flex: 0 0 auto;
  margin-left: 14rpx;
  color: #C0C9D6;
  font-size: 40rpx;
}

.mc-badge {
  display: inline-block;
  margin-top: 12rpx;
  padding: 4rpx 16rpx;
  border-radius: 10rpx;
  color: #8C7355;
  font-size: 20rpx;
  font-weight: 700;
  background: #FBF8F5;
}

.mc-row {
  display: flex;
  margin-top: 16rpx;
  font-size: 23rpx;
}

.mc-k {
  flex: 0 0 130rpx;
  color: #8C8C8C;
}

.mc-v {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #4A4A4A;
}

/* Promo */
.promo {
  margin-top: 8rpx;
  padding: 30rpx 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #FFF9E6, #FFFDF0);
  border: 1rpx solid rgba(201, 162, 39, 0.2);
}

.promo-title {
  color: #2A2207;
  font-size: 28rpx;
  font-weight: 800;
}

.promo-sub {
  margin-top: 10rpx;
  color: #8C7355;
  font-size: 22rpx;
}

.promo-row {
  display: flex;
  margin-top: 26rpx;
}

.promo-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.promo-ic {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  color: #C9A227;
  background: #FFFFFF;
}

.promo-ic .iconfont {
  font-size: 44rpx;
}

.promo-name {
  margin-top: 14rpx;
  color: #2A2207;
  font-size: 25rpx;
  font-weight: 700;
}

.promo-soon {
  margin-top: 6rpx;
  color: #8C7355;
  font-size: 20rpx;
}

/* Lists */
.card-list {
  border-radius: 22rpx;
  overflow: hidden;
}

.ledger,
.item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
  padding: 24rpx 26rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(201, 162, 39, 0.08);
}

.ledger > view {
  flex: 1;
  min-width: 0;
}

.ledger > view > text,
.item > view > text {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.item > view > text {
  color: #C9A227;
  font-size: 32rpx;
  font-weight: 800;
}

.ledger > view > label,
.item > view > label {
  display: block;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #8C8C8C;
  font-size: 21rpx;
}

.ledger .minus {
  flex: 0 0 auto;
  margin-left: 20rpx;
  color: #1A1A1A;
  font-size: 30rpx;
  font-weight: 800;
}

.date {
  flex: 0 0 auto;
  margin-left: 20rpx;
  color: #8C8C8C;
  font-size: 22rpx;
}

.section-empty {
  padding: 44rpx 0;
  text-align: center;
  border-radius: 22rpx;
  color: #8C8C8C;
  font-size: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(201, 162, 39, 0.08);
}

/* Terms modal */
.terms-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
  background: rgba(11, 22, 45, 0.6);
}

.terms-sheet {
  width: 100%;
  max-width: 640rpx;
  padding: 40rpx 32rpx 32rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.terms-title {
  text-align: center;
  color: #1A1A1A;
  font-size: 34rpx;
  font-weight: 800;
}

.terms-tip {
  margin-top: 10rpx;
  text-align: center;
  color: #8C8C8C;
  font-size: 24rpx;
}

.terms-body {
  max-height: 640rpx;
  margin: 24rpx 0;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #F5F3F0;
}

.terms-item {
  display: flex;
  margin-bottom: 18rpx;
  line-height: 1.6;
}

.terms-idx {
  flex-shrink: 0;
  width: 36rpx;
  color: #C9A227;
  font-size: 26rpx;
  font-weight: 700;
}

.terms-text {
  flex: 1;
  color: #4A4A4A;
  font-size: 26rpx;
}

.terms-agree-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #1A1F36 0%, #2D3561 100%);
}

.terms-agree-btn.disabled {
  background: #d0d0d0;
  color: rgba(255, 255, 255, 0.85);
}
