.page{min-height:100vh;background:#f5f3f0;padding:24rpx 24rpx 60rpx;box-sizing:border-box}.balance{background:linear-gradient(135deg,#1a1f36,#343b62);color:#fff;border-radius:24rpx;padding:38rpx}.balance>view:first-child{font-size:25rpx;color:#c8cada}.balance>text{display:block;font-size:62rpx;color:#e4c96c;font-weight:700;margin:14rpx 0}.balance>label{font-size:22rpx;color:#aaaec3}.totals{display:flex;border-top:1rpx solid rgba(255,255,255,.13);margin-top:28rpx;padding-top:24rpx}.totals>view{width:50%;display:flex;flex-direction:column}.totals>view+view{padding-left:35rpx;border-left:1rpx solid rgba(255,255,255,.13)}.totals text{font-size:30rpx;color:#f0dc98;font-weight:600}.totals label{font-size:21rpx;color:#aaaec3;margin-top:6rpx}.title{display:flex;justify-content:space-between;align-items:center;font-size:28rpx;font-weight:600;color:#252a3d;margin:34rpx 6rpx 16rpx}.title label{font-size:21rpx;font-weight:400;color:#999}.merchant-scroll{width:100%;white-space:nowrap}.merchant-row{display:flex;gap:16rpx}.merchant{display:inline-block;flex:none;width:470rpx;background:#fff;border-radius:18rpx;padding:18rpx;box-sizing:border-box;white-space:normal}.merchant-cover{width:100%;height:190rpx;border-radius:14rpx;background:#eee}.merchant-cover.fallback{display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#2d3561,#c9a227);color:#fff;font-size:64rpx;font-weight:700}.merchant-name{font-size:29rpx;font-weight:600;color:#1a1f36;margin-top:16rpx}.merchant-category{font-size:21rpx;color:#9b7715;margin-top:7rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.merchant-address{font-size:22rpx;color:#888;margin-top:9rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.merchant-actions{display:flex;gap:12rpx;margin-top:16rpx}.merchant-actions button{flex:1;height:58rpx;line-height:58rpx;font-size:23rpx;background:#f8f6f1;color:#826617}.item,.ledger{display:flex;justify-content:space-between;align-items:center;background:#fff;padding:24rpx;border-radius:16rpx;margin-bottom:12rpx}.item text{display:block;font-size:32rpx;color:#b48b16;font-weight:600}.item label,.ledger label{display:block;font-size:21rpx;color:#aaa;margin-top:6rpx}.date{font-size:22rpx;color:#888}.ledger>view{flex:1;min-width:0}.ledger>view>text{font-size:26rpx;color:#333}.ledger>view>label{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.ledger>text{font-size:28rpx;font-weight:600;margin-left:20rpx}.minus{color:#777}.section-empty{text-align:center;background:#fff;border-radius:16rpx;padding:42rpx 0;color:#aaa;font-size:24rpx}
.qr-card{background:#fff;border-radius:16rpx;padding:32rpx 24rpx 28rpx;margin-bottom:8rpx;text-align:center}
.qr-title{font-size:28rpx;font-weight:600;color:#282828;margin-bottom:20rpx}
.qr-wrap{display:flex;justify-content:center;align-items:center;padding:12rpx 0}
.qr-hint{font-size:24rpx;color:#888;margin-top:16rpx;line-height:1.5}
.qr-uid{font-size:22rpx;color:#999;margin-top:8rpx}
.qr-terms-link{display:inline-block;margin-top:16rpx;font-size:22rpx;color:#9b7715;text-decoration:underline}
.terms-lock{display:flex;flex-direction:column;align-items:center;background:#fff;border:1rpx dashed rgba(201,162,39,.4);border-radius:24rpx;padding:48rpx 28rpx;margin-bottom:8rpx;text-align:center}
.lock-icon{font-size:56rpx;margin-bottom:12rpx}
.lock-title{font-size:28rpx;font-weight:700;color:#282828}
.lock-sub{font-size:24rpx;color:#9b7715;margin-top:8rpx}
.terms-mask{position:fixed;left:0;right:0;top:0;bottom:0;z-index:9999;background:rgba(26,31,54,.6);display:flex;align-items:center;justify-content:center;padding:48rpx;box-sizing:border-box}
.terms-sheet{width:100%;max-width:640rpx;background:#fff;border-radius:28rpx;padding:40rpx 32rpx 32rpx;box-sizing:border-box;box-shadow:0 20rpx 60rpx rgba(0,0,0,.3)}
.terms-title{font-size:34rpx;font-weight:800;color:#282828;text-align:center}
.terms-tip{font-size:24rpx;color:#999;text-align:center;margin-top:10rpx}
.terms-body{max-height:640rpx;margin:24rpx 0;padding:24rpx;background:#f5f3f0;border-radius:16rpx;box-sizing:border-box}
.terms-item{display:flex;margin-bottom:18rpx;line-height:1.6}
.terms-idx{flex-shrink:0;width:36rpx;font-size:26rpx;font-weight:700;color:#9b7715}
.terms-text{flex:1;font-size:26rpx;color:#555}
.terms-agree-btn{width:100%;height:92rpx;line-height:92rpx;border-radius:46rpx;background:linear-gradient(135deg,#e4c96c,#9b7715);color:#fff;font-size:30rpx;font-weight:700}
.terms-agree-btn.disabled{background:#d0d0d0;color:rgba(255,255,255,.85)}