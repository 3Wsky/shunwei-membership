<view class="page">
  <view class="merchant-head">
    <view class="head-label">当前权益商家</view>
    <view class="merchant-name">{{merchant.merchantName}}</view>
    <view class="merchant-sub">{{merchant.categoryText || merchant.category || '数码3C'}}</view>
  </view>

  <view class="info-card">
    <view class="card-title">门店信息</view>
    <view class="info-row">
      <label>营业时间</label>
      <text>{{merchant.hoursText || merchant.businessHours || '营业时间请咨询'}}</text>
    </view>
    <view class="info-row">
      <label>门店地址</label>
      <text>{{merchant.addressText || merchant.storeAddress || '门店地址请咨询'}}</text>
    </view>
    <view class="info-row">
      <label>联系电话</label>
      <text>{{merchant.contactPhone || '暂无联系电话'}}</text>
    </view>
  </view>

  <view class="benefit-card">
    <view class="card-title">权益说明</view>
    <view class="benefit-line">支持会员现金券核销</view>
    <view class="benefit-desc">到店消费时出示“我的现金券”二维码，商家/店员扫码后即可识别会员身份并完成核销。</view>
  </view>

  <view class="actions">
    <button bindtap="openLocation">导航到店</button>
    <button class="primary" bindtap="callMerchant">拨打电话</button>
  </view>
</view>
